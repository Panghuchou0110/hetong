    function getTableExportColumns(includeRunawayAmount) {
      if (!includeRunawayAmount) return exportColumns;
      return [
        ...exportColumns.slice(0, 8),
        { key: "runaway_amount", label: "已转客户金额" },
        ...exportColumns.slice(8),
      ];
    }
    const csvRequiredKeys = csvColumns.filter((col) => col.key !== "remark").map((col) => col.key);
    const csvLabelToKey = csvColumns.reduce((acc, col) => {
      acc[col.label] = col.key;
      return acc;
    }, {});

    function toCsv(rows, headers) {
      const lines = [];
      lines.push(headers.join(","));
      rows.forEach((row) => {
        const line = headers.map((key) => csvEscape(row[key]));
        lines.push(line.join(","));
      });
      return "\uFEFF" + lines.join("\n");
    }

    function toCsvWithLabels(rows, columns) {
      const lines = [];
      lines.push(columns.map((col) => csvEscape(col.label)).join(","));
      rows.forEach((row) => {
        const line = columns.map((col) => csvEscape(row[col.key]));
        lines.push(line.join(","));
      });
      return "\uFEFF" + lines.join("\n");
    }

    function formatRemarkPlain(remark) {
      const raw = String(remark || "");
      const tagPattern = /\u3010[^\u3011]+\u3011/g;
      const tags = raw.match(tagPattern) || [];
      const rest = raw.replace(tagPattern, "").trim();
      return `${tags.join(" ")}${tags.length && rest ? " " : ""}${rest}`.trim();
    }

