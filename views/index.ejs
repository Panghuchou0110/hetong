        return;
      }
      const data = collectContractData();
      if (!validateContract(data)) return;
      const shouldAddOrder = await openAddOrderPrompt();
      if (shouldAddOrder) {
        addOrder(data);
        updateSection("section-orders", "卡片订单");
      }
      const response = await fetch("/generate", {
