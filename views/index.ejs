    function buildAlertGroups(nowTs) {
      const groupSigned = [];
      const groupUnstored = [];
      const groupActivationPending = [];
      const groupMismatch = [];
      const groupStoredMissingActual = [];
      const dayMs = 24 * 60 * 60 * 1000;
      orders.forEach((order) => {
        if (order.status === "unsigned") return;
        const createdAt = Number(order.createdAt) || 0;
        if (!createdAt) return;
        const ageDays = Math.floor((nowTs - createdAt) / dayMs);
        const label = `${order.seller_name || "未填写"} / ${order.model || "未填写"} ${order.memory || ""} ${
          order.color || ""
        }`;
        if (order.status === "signed" && ageDays >= 3) {
          groupSigned.push({
            id: order.id,
            type: `超${ageDays}天还未拉群`,
            text: `${label}（下单${formatOrderDate(createdAt)}）`,
          });
          return;
        }
        if (
          order.status !== "stored" &&
          order.status !== "stored_mismatch" &&
          order.status !== "refunded" &&
          order.status !== "runaway" &&
          ageDays >= 7
        ) {
          groupUnstored.push({
            id: order.id,
            type: `超${ageDays}天还未入库`,
            text: `${label}（下单${formatOrderDate(createdAt)}）`,
          });
        }
        const activation = resolveActivation(order);
        if (activation.label === "仅激活（待补差）" || activation.label === "预激活（待补差）") {
          const settled = formatPrice(parsePrice(order.settle_price));
          groupActivationPending.push({
            id: order.id,
            type: "激活待补差",
            text: `${label}（下单${formatOrderDate(createdAt)}），当前已结${settled || "0"}元`,
          });
        }
        if (order.status === "stored_mismatch" && !String(order.remark || "").includes("【已补差】")) {
          groupMismatch.push({
            id: order.id,
            type: "型号不对待补差",
            text: `${label}（下单${formatOrderDate(createdAt)}）`,
          });
        }
        if (order.status === "stored" && !String(order.actual_model_color || "").trim()) {
          groupStoredMissingActual.push({
            id: order.id,
            type: "已入库未填实际型号",
            text: `${label}（下单${formatOrderDate(createdAt)}）`,
          });
        }
      });
      return { groupSigned, groupUnstored, groupActivationPending, groupMismatch, groupStoredMissingActual };
    }


    function renderTrash() {
      const list = $("trashList");
      list.innerHTML = "";
      $("trashCount").textContent = `共 ${trashedOrders.length} 单`;
      $("trashLocked").style.display = trashUnlocked ? "none" : "block";
      $("trashList").style.display = trashUnlocked ? "grid" : "none";
      $("trashEmpty").style.display = trashUnlocked && trashedOrders.length ? "none" : trashUnlocked ? "block" : "none";
      if (!trashUnlocked) {
        return;
      }
      let changed = false;
      const grouped = trashedOrders.reduce((acc, order) => {
        const key = formatOrderDate(order.createdAt);
        if (!acc[key]) acc[key] = [];
        acc[key].push(order);
        return acc;
      }, {});
      const groupKeys = Object.keys(grouped);
      groupKeys.forEach((dateKey, groupIndex) => {
        const dateCard = document.createElement("div");
        dateCard.className = "order-date-card";
        dateCard.style.setProperty("--delay", `${groupIndex * 0.05}s`);
        dateCard.textContent = `${dateKey} 卡片订单`;
        list.appendChild(dateCard);
        grouped[dateKey].forEach((order, index) => {
        if (!order.color) {
          order.color = randomColorForModel(order.model);
          changed = true;
        }
        const card = document.createElement("div");
        card.className = `order-card status-${order.status || "signed"}`;
        card.dataset.id = order.id;
        card.style.setProperty("--delay", `${index * 0.05}s`);
        const actionsHtml = `
          <button class="secondary" data-action="restore" type="button">恢复</button>
          <button class="danger" data-action="delete" type="button">彻底删除</button>
        `;
        card.innerHTML = orderCardHtml(order, { actionsHtml });
        list.appendChild(card);
        });
      });
      if (changed) {
        saveTrash();
      }
    }

    function renderOperationLogs() {
      const list = $("operationLogList");
      const empty = $("operationLogEmpty");
      if (!list || !empty) return;
      list.innerHTML = "";
      if (!operationLogs.length) {
        empty.textContent = "最近 7 天暂无操作记录。";
        empty.style.display = "block";
        return;
      }
      empty.style.display = "none";
      operationLogs.forEach((log) => {
        const item = document.createElement("div");
        item.className = "operation-log-item";
        const undoneAt = Number(log.undone_at) || 0;
        const canUndo = !undoneAt && Number(log.can_undo) === 1 && Number(log.after_version) === Number(stateVersion);
        const undoStatus = undoneAt
          ? `已撤回：${escapeHtml(log.undone_by || "unknown")} · ${escapeHtml(formatOperationLogTime(undoneAt))}`
          : canUndo
            ? "可撤回"
            : "不可撤回";
        item.innerHTML = `
          <div class="operation-log-head">
            <div>
              <div class="operation-log-title">${escapeHtml(log.summary || "数据变更")}</div>
              <div class="operation-log-meta">
                ${escapeHtml(formatOperationLogTime(Number(log.created_at)) || "--")} · ${escapeHtml(log.user || "unknown")} · ${escapeHtml(log.action || "操作")} · ${undoStatus}
              </div>
            </div>
            ${
              canUndo
                ? `<button class="secondary" type="button" data-action="undo-operation-log" data-id="${escapeHtml(log.id)}">撤回</button>`
                : ""
            }
          </div>
          <div class="operation-log-detail">${escapeHtml(log.detail || log.summary || "")}</div>
        `;
        list.appendChild(item);
      });
    }

    async function loadOperationLogs(force = false) {
      if (operationLogsLoaded && !force) {
        renderOperationLogs();
        return;
      }
      const list = $("operationLogList");
      const empty = $("operationLogEmpty");
      if (list) {
        list.innerHTML = '<div class="empty-state">正在读取操作记录...</div>';
      }
      if (empty) empty.style.display = "none";
      if (empty) empty.textContent = "最近 7 天暂无操作记录。";
      try {
        const response = await fetch("/api/operation-logs");
        if (response.status === 401) {
          handleUnauthorized();
          return;
        }
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) throw new Error(result.error || "operation_logs_failed");
        operationLogs = Array.isArray(result.logs) ? result.logs : [];
        operationLogsLoaded = true;
        renderOperationLogs();
      } catch (err) {
        console.error("operation logs failed", err);
        if (list) list.innerHTML = "";
        if (empty) {
          empty.style.display = "block";
          empty.textContent = "操作记录读取失败，请稍后重试。";
        }
      }
    }

    async function undoOperationLog(id) {
      if (!id) return;
      if (!confirm("确认撤回这次操作吗？撤回会恢复到这次操作之前的数据；如果之后已有新修改，系统会拒绝撤回。")) return;
      openSafetyPassword(async () => {
        try {
          const response = await fetch(`/api/operation-logs/${encodeURIComponent(id)}/undo`, { method: "POST" });
          if (response.status === 401) {
            handleUnauthorized();
            return;
          }
          const result = await response.json().catch(() => ({}));
          if (!response.ok || !result.ok) {
            const messageMap = {
              already_undone: "这条记录已经撤回过。",
              undo_not_available: "这条记录不支持撤回。",
              state_changed: "撤回失败：这次操作之后已有新修改。为避免覆盖新数据，请先备份后手动处理。",
              log_not_found: "没有找到这条操作记录。",
              undo_state_corrupted: "撤回快照损坏，不能自动撤回。",
            };
            alert(messageMap[result.error] || "撤回失败，请稍后重试。");
            return;
          }
          alert("已撤回本次操作，并写入撤回记录。页面将刷新最新数据。");
          window.location.reload();
        } catch (err) {
          console.error("operation undo failed", err);
          alert("撤回失败，请检查服务器状态。");
        }
      }, {
        title: "撤回操作验证",
        hint: "撤回会恢复到该操作之前的数据，需要管理员密码确认。",
        label: "管理员密码",
      });
    }

