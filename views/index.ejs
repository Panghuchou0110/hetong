    async function initApp() {
      try {
      const state = await fetchState();
      if (!state) return false;
        orders = (state.orders || []).map(applyOrderRules);
        trashedOrders = (state.trash || []).map(applyOrderRules);
        sources = state.sources;
        defaultSource = typeof state.defaultSource === "string" && state.defaultSource ? state.defaultSource : "皖顺";
        authRememberHours = state.authRememberHours && typeof state.authRememberHours === "object" ? state.authRememberHours : {};
        models = normalizeList(state.models || []);
        modelColors = state.modelColors && typeof state.modelColors === "object" ? state.modelColors : { ...defaultModelColors };
        if (models.length === 0) models = [...defaultModels];
        if (!modelColors || Object.keys(modelColors).length === 0) modelColors = { ...defaultModelColors };
        if (normalizeOrderIds()) {
          saveOrders();
          saveTrash();
        }
        ensureSourcesFromOrders();
        ensureConfigFromOrders();
        setupSidebar();
        setupOrderGroup();
        setupNavigation();
        renderOrders();
        renderTrash();
        renderHome();
        renderSourceSelects();
        renderSourceList();
        updateAccountManagementVisibility();
        renderModelSelects();
        renderColorFilterSelect();
        renderModelList();
        renderColorList();
        refreshColorSelects();
        renderActualModelColorSelects();
        $("order_date").value = formatDateInput(getBeijingNow().getTime());
        const today = getBeijingNow().getTime();
        $("filter_end").value = formatDateValue(today);
        $("filter_start").value = formatDateValue(today - 7 * 24 * 60 * 60 * 1000);
        $("runaway_filter_end").value = formatDateValue(today);
        $("runaway_filter_start").value = formatDateValue(today - 365 * 24 * 60 * 60 * 1000);
        const now = getBeijingNow();
        const tableStart = new Date(now);
        tableStart.setDate(tableStart.getDate() - 29);
        tableStart.setHours(0, 0, 0, 0);
        const tableEnd = new Date(now);
        tableEnd.setHours(23, 59, 59, 999);
        $("table_filter_end").value = formatDateValue(tableEnd.getTime());
        $("table_filter_start").value = formatDateValue(tableStart.getTime());
        const filterCard = $("filterToggle").closest(".card");
        const filterCollapsed = localStorage.getItem("filter_collapsed");
        if (filterCollapsed === "0") {
          filterCard.classList.remove("filter-collapsed");
        }
        const tableFilterCard = $("tableFilterToggle").closest(".card");
        const tableFilterCollapsed = localStorage.getItem("table_filter_collapsed");
        if (tableFilterCollapsed === "0") {
          tableFilterCard.classList.remove("filter-collapsed");
        }
        applyTableViewPreset("all");
        renderOrderTable();
        return true;
      } catch (err) {
        console.error("\u521d\u59cb\u5316\u5931\u8d25", err);
        return false;
      }
    }

    let appLoaded = false;
    async function ensureAppLoaded() {
      if (appLoaded) return true;
      const ok = await initApp();
      if (ok) appLoaded = true;
      return appLoaded;
    }

    const themeToggle = $("themeToggle");
    const savedTheme = localStorage.getItem("theme_mode");
    const themeModeText = $("themeModeText");
    function applyTheme(mode) {
      const darkMode = mode === "dark";
      document.body.classList.toggle("dark", darkMode);
      themeToggle.checked = darkMode;
      if (themeModeText) themeModeText.textContent = darkMode ? "暗夜模式" : "日间模式";
      localStorage.setItem("theme_mode", darkMode ? "dark" : "light");
    }
    if (savedTheme === "dark" || savedTheme === "light") {
      applyTheme(savedTheme);
    } else {
      applyTheme("light");
    }
    themeToggle.addEventListener("change", () => {
      applyTheme(themeToggle.checked ? "dark" : "light");
    });

    const loginMask = $("loginMask");
    const loginUser = $("loginUser");
    const loginPass = $("loginPass");
    const rememberMe = $("rememberMe");
    const btnLogin = $("btnLogin");

    function handleUnauthorized() {
      localStorage.removeItem("remember_login");
      appLoaded = false;
      showLogin();
    }

    function showLogin() {
      document.body.classList.add("locked");
      loginMask.style.display = "flex";
      document.body.style.overflow = "hidden";
    }

    function hideLogin() {
      document.body.classList.remove("locked");
      loginMask.style.display = "none";
      document.body.style.overflow = "";
    }

    function tryAutoLogin() {
      const saved = localStorage.getItem("remember_login");
      if (!saved) return false;
      try {
        const { user, expiresAt } = JSON.parse(saved);
        if (!user || !expiresAt) return false;
        if (Date.now() >= expiresAt) {
          localStorage.removeItem("remember_login");
          return false;
        }
        loginUser.value = user;
        return true;
      } catch (err) {
        return false;
      }
    }

    const loginRememberFallbackMs = 24 * 60 * 60 * 1000;

    async function verifyLogin(user, pass) {
      try {
        const response = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ user, pass }),
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) return { ok: false };
        return { ok: true, expiresIn: Number(result.expiresIn) };
      } catch (err) {
        return { ok: false };
      }
    }

    async function doLogin() {
      const user = loginUser.value.trim();
      const pass = loginPass.value.trim();
      if (!user || !pass) {
        alert("\u8bf7\u8f93\u5165\u8d26\u53f7\u548c\u5bc6\u7801");
        return;
      }
      btnLogin.disabled = true;
      const result = await verifyLogin(user, pass);
      btnLogin.disabled = false;
      if (!result.ok) {
        alert("\u8d26\u53f7\u6216\u5bc6\u7801\u9519\u8bef");
        loginPass.value = "";
        return;
      }
      if (rememberMe.checked) {
        const ttlMs =
          Number.isFinite(result.expiresIn) && result.expiresIn > 0
            ? result.expiresIn * 1000
            : loginRememberFallbackMs;
        localStorage.setItem(
          "remember_login",
          JSON.stringify({ user, expiresAt: Date.now() + ttlMs })
        );
      } else {
        localStorage.removeItem("remember_login");
      }
      const loaded = await ensureAppLoaded();
      if (!loaded) return;
      hideLogin();
      updateTopbarGreeting();
      updateAccountManagementVisibility();
      alert("\u767b\u5f55\u6210\u529f\uff0c24\u5c0f\u65f6\u5185\u65e0\u9700\u518d\u767b\u5f55\u3002");
    }

    btnLogin.addEventListener("click", doLogin);
    loginPass.addEventListener("keydown", (event) => {
      if (event.key === "Enter") doLogin();
    });

    $("btnLogout").addEventListener("click", async () => {
      if (!confirm("确定要退出登录吗？")) return;
      try {
        await fetch("/api/auth/logout", { method: "POST" });
      } catch (err) {
        // ignore logout errors
      }
      localStorage.removeItem("remember_login");
      showLogin();
      updateTopbarGreeting();
    });

    if (tryAutoLogin()) {
      ensureAppLoaded().then((loaded) => {
        if (!loaded) return;
        hideLogin();
        updateAccountManagementVisibility();
      });
    } else {
      showLogin();
    }
    updateTopbarGreeting();
    syncBackdrop();
    window.addEventListener("resize", syncBackdrop);
  </script>
</body>
</html>

