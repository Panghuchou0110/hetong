    function updateSection(targetId, label) {
      document.querySelectorAll(".section").forEach((section) => {
        section.classList.toggle("active", section.id === targetId);
      });
      document.querySelectorAll(".nav button[data-target]").forEach((btn) => {
        const sameTarget = btn.dataset.target === targetId;
        const targetView = btn.dataset.tableView || "";
        const runawayView = btn.dataset.runawayView || "";
        const isActiveTableView = targetId === "section-orders-table" && targetView === currentTableView;
        const isActiveRunawayView = targetId === "section-runaway" && runawayView === currentRunawayView;
        btn.classList.toggle(
          "active",
          isActiveTableView || isActiveRunawayView || (sameTarget && targetId !== "section-orders-table" && targetId !== "section-runaway")
        );
      });
      const title = targetId === "section-home" ? "今日订单" : label;
      $("pageTitle").textContent = title;
      if (targetId === "section-add" && !$("order_date").value) {
        $("order_date").value = formatDateInput(getBeijingNow().getTime());
      }
      if (targetId === "section-safety" && !trashUnlocked) {
        openTrashPasswordModal();
      }
      if (targetId === "section-safety") {
        loadOperationLogs();
      }
      if (targetId !== "section-contract") {
        $("orderGroup").classList.remove("collapsed");
        $("orderGroupWrap").classList.remove("collapsed");
        $("orderGroupArrow").textContent = "▾";
      }
      if (targetId !== "section-runaway") {
        setRunawayNavExpanded(false);
      } else {
        applyRunawayViewPreset(currentRunawayView);
      }
      updateTopbarGreeting();
      syncBackdrop();
    }

