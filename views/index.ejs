    function openBatchFillPrice() {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      if (!confirmBatchAction("按客户填写结算价")) return;
      const selected = orders.filter((order) => selectedOrderIds.has(order.id));
      const hasExisting = selected.some((order) => parsePrice(order.settle_price) > 0);
      const missing = selected.filter((order) => parsePrice(order.settle_price) <= 0);
      if (missing.length === 0) {
        const shouldSettle = confirm("全部已有结算价，是否更新为已结算状态？");
        if (!shouldSettle) return;
        orders = orders.map((order) => {
          if (!selectedOrderIds.has(order.id)) return order;
          return { ...order, settlement: "settled" };
        });
        selectedOrderIds.clear();
        saveOrders();
        renderOrders();
        return;
      }
      if (hasExisting) {
        const modify = confirm("已包含有结算价的订单，是否也要修改这些价格？");
        pendingPriceOrders = modify ? selected : missing;
      } else {
        pendingPriceOrders = missing;
      }
      pendingPriceIndex = 0;
      pendingPriceDraft = new Map();
      renderBatchPriceStep();
      openModal("batchPriceModal");
    }

    function renderBatchPriceStep() {
      const current = pendingPriceOrders[pendingPriceIndex];
      if (!current) return;
      const activation = resolveActivation(current);
      const name = current.seller_name || "未填写姓名";
      const label = `${current.model || "未填写"} ${current.memory || ""} ${current.color || ""}`.trim();
      const activationText = activation.label;
      $("batchPriceLabel").innerHTML = `${escapeHtml(name)} / ${escapeHtml(label)} / <span class="activation-status ${activation.className}">${activationText}</span>`;
      const activationHint = activation.label.startsWith("仅激活") ? "（仅激活）" : "";
      $("batchPriceProgress").textContent = `待填写 ${pendingPriceIndex + 1} / ${pendingPriceOrders.length}${activationHint}`;
      const saved = pendingPriceDraft.get(current.id);
      $("batchPriceInput").value = saved ?? "";
      $("btnBatchPricePrev").disabled = pendingPriceIndex === 0;
      $("btnBatchPriceNext").textContent = pendingPriceIndex === pendingPriceOrders.length - 1 ? "完成" : "下一条";
    }

    function saveCurrentPrice() {
      const current = pendingPriceOrders[pendingPriceIndex];
      if (!current) return false;
      const value = parsePrice($("batchPriceInput").value);
      if (value <= 0) {
        alert("结算价不能为空或为 0");
        return false;
      }
      pendingPriceDraft.set(current.id, value);
      return true;
    }

    function handleBatchPriceNext() {
      if (!saveCurrentPrice()) return;
      if (pendingPriceIndex < pendingPriceOrders.length - 1) {
        pendingPriceIndex += 1;
        renderBatchPriceStep();
        return;
      }
      const missing = pendingPriceOrders.filter((order) => !pendingPriceDraft.has(order.id));
      if (missing.length) {
        alert("仍有订单未填写结算价");
        return;
      }
      const shouldSettle = confirm("是否同时更新为已结算状态？");
      orders = orders.map((order) => {
        if (!selectedOrderIds.has(order.id)) return order;
        const draft = pendingPriceDraft.get(order.id);
        if (draft) {
          return shouldSettle
            ? { ...order, settle_price: draft, settlement: "settled" }
            : { ...order, settle_price: draft };
        }
        return shouldSettle ? { ...order, settlement: "settled" } : order;
      });
      pendingPriceOrders = [];
      pendingPriceDraft.clear();
      selectedOrderIds.clear();
      saveOrders();
      renderOrders();
      closeModal("batchPriceModal");
    }




    function handleBatchPricePrev() {
      if (pendingPriceIndex === 0) return;
      pendingPriceIndex -= 1;
      renderBatchPriceStep();
    }

    function closeBatchPriceModal() {
      pendingPriceOrders = [];
      pendingPriceDraft.clear();
      closeModal("batchPriceModal");
    }

    function buildModelPriceGroups(list) {
      const map = new Map();
      list.forEach((order) => {
        const activation = resolveActivation(order);
        const model = String(order.model || "未填写机型").trim() || "未填写机型";
        const memory = String(order.memory || "未填写容量").trim() || "未填写容量";
        const color = String(order.color || "未填写颜色").trim() || "未填写颜色";
        const key = JSON.stringify([model, memory, color, activation.label]);
        if (!map.has(key)) {
          map.set(key, {
            key,
            label: `${model} ${memory} ${color}`,
            activation,
            orders: [],
          });
        }
        map.get(key).orders.push(order);
      });
      return Array.from(map.values()).sort((a, b) => {
        const left = `${a.label} ${a.activation.label}`;
        const right = `${b.label} ${b.activation.label}`;
        return left.localeCompare(right, "zh-Hans-CN");
      });
    }

    function openBatchFillModelPrice() {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      if (!confirmBatchAction("按机型填写结算价")) return;
      const selected = orders.filter((order) => selectedOrderIds.has(order.id));
      const hasExisting = selected.some((order) => parsePrice(order.settle_price) > 0);
      const missing = selected.filter((order) => parsePrice(order.settle_price) <= 0);
      if (missing.length === 0) {
        const shouldSettle = confirm("全部已有结算价，是否更新为已结算状态？");
        if (!shouldSettle) return;
        orders = orders.map((order) => {
          if (!selectedOrderIds.has(order.id)) return order;
          return { ...order, settlement: "settled" };
        });
        selectedOrderIds.clear();
        saveOrders();
        renderOrders();
        return;
      }
      const targetOrders = hasExisting
        ? confirm("已包含有结算价的订单，是否也要按机型覆盖这些价格？\n\n确定：覆盖所选订单价格\n取消：只填写未填结算价的订单")
          ? selected
          : missing
