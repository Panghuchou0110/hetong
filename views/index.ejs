    function parseCsv(text) {
      const rows = [];
      let row = [];
      let field = "";
      let inQuotes = false;
      for (let i = 0; i < text.length; i += 1) {
        const ch = text[i];
        const next = text[i + 1];
        if (inQuotes) {
          if (ch === "\"" && next === "\"") {
            field += "\"";
            i += 1;
          } else if (ch === "\"") {
            inQuotes = false;
          } else {
            field += ch;
          }
        } else {
          if (ch === "\"") {
            inQuotes = true;
          } else if (ch === ",") {
            row.push(field);
            field = "";
          } else if (ch === "\n") {
            row.push(field);
            rows.push(row);
            row = [];
            field = "";
          } else if (ch !== "\r") {
            field += ch;
          }
        }
      }
      if (field.length || row.length) {
        row.push(field);
        rows.push(row);
      }
      return rows;
    }

