    function validateOrder(data, prefix) {
      let valid = true;
      clearErrors(prefix);
      if (!data.seller_name) {
        setFieldError(prefix, "name", "请输入客户姓名");
        valid = false;
      } else if (!/^[\u4e00-\u9fa5]{2,4}$/.test(data.seller_name)) {
        setFieldError(prefix, "name", "客户姓名必须是2-4个中文字符");
        valid = false;
      }
      if (data.seller_id && !isValidChineseId(data.seller_id)) {
        setFieldError(prefix, "id", "身份证格式不正确");
        valid = false;
      }
      if (data.seller_phone && !isValidPhone(data.seller_phone)) {
        setFieldError(prefix, "phone", "手机号格式不正确");
        valid = false;
      }
      if (!data.model) {
        setFieldError(prefix, "model", "请输入机型");
        valid = false;
      }
      if (!data.memory) {
        setFieldError(prefix, "memory", "请输入容量");
        valid = false;
      }
      if (!data.color) {
        setFieldError(prefix, "color", "请选择颜色");
        valid = false;
      }
      if (prefix !== "order" && !data.buy_price) {
        setFieldError(prefix, "buy_price", "请输入回收价格");
        valid = false;
      } else if (data.buy_price) {
        const buyValue = Number(data.buy_price);
        if (!Number.isFinite(buyValue) || buyValue < 2000 || buyValue > 20000) {
          setFieldError(prefix, "buy_price", "回收价格需在 2000-20000 之间");
          valid = false;
        }
      }
      if (data.settle_price) {
        const settleValue = Number(data.settle_price);
        if (!Number.isFinite(settleValue) || settleValue < 0) {
          setFieldError(prefix, "settle_price", "结算价格需为正数");
          valid = false;
        }
      }
      if (prefix !== "order" && !data.status) {
        setFieldError(prefix, "status", "请选择状态");
        valid = false;
      }
      return valid;
    }

    function formatPrice(value) {
      const num = Number(value);
      if (!Number.isFinite(num)) return value || "";
      return num.toLocaleString("zh-CN");
    }

    function parsePrice(value) {
      if (value === null || value === undefined) return 0;
      const num = Number(String(value).replace(/,/g, ""));
      return Number.isFinite(num) ? num : 0;
    }

    function formatPlainPrice(value) {
      const num = Number(value);
      if (!Number.isFinite(num)) return "0";
      return Number.isInteger(num) ? String(num) : String(num);
    }

    function formatConfirmValue(value) {
      const text = String(value ?? "").trim();
      return text ? text : "空";
    }

    function isValidOrderId(value) {
      const text = String(value || "");
      if (!/^\d{5}$/.test(text)) return false;
      const num = Number(text);
      return num >= 10001 && num <= 99999;
    }

    function getMaxOrderId() {
      let max = 10000;
      orders.concat(trashedOrders).forEach((order) => {
        if (!order || !isValidOrderId(order.id)) return;
        const num = Number(order.id);
        if (num > max) max = num;
      });
      return max;
    }

    function getNextOrderIdFromMax(currentMax) {
      const next = Number(currentMax) + 1;
      if (next > 99999) return "";
      return String(next);
    }

    function generateOrderId() {
      const max = getMaxOrderId();
      return getNextOrderIdFromMax(max);
    }

    function normalizeOrderIds() {
      const all = orders.concat(trashedOrders);
      const sorted = all.slice().sort((a, b) => (Number(a.createdAt) || 0) - (Number(b.createdAt) || 0));
      let expected = 10001;
      let needsRenumber = false;
      for (const order of sorted) {
        if (!order) continue;
        const current = String(order.id || "");
        if (current !== String(expected)) {
          needsRenumber = true;
          break;
        }
        expected += 1;
      }
      if (!needsRenumber) return false;
      let next = 10001;
      sorted.forEach((order) => {
        if (!order) return;
        order.id = String(next);
        next += 1;
      });
      return true;
    }

    function applyRefundRules(order) {
      if (!order || order.status !== "refunded") return order;
      const original = parsePrice(order.settle_price) || parsePrice(order.buy_price);
      const settledText = formatPlainPrice(original);
      const refundNote = `已结算${settledText}，已退款`;
      const remark = String(order.remark || "").trim();
      const nextRemark = remark.includes("已退款") ? remark : remark ? `${remark}；${refundNote}` : refundNote;
      return {
        ...order,
        settle_price: "0",
        settlement: "settled",
        remark: nextRemark,
      };
    }

    function normalizeSpec(value) {
      return String(value || "").replace(/\s+/g, "");
    }

    function isOrderSpecMismatch(order) {
      const modelText = [order.model, order.memory, order.color].filter(Boolean).join(" ").trim();
      const actualText = String(order.actual_model_color || "").trim();
      if (!actualText) return false;
      return normalizeSpec(actualText) !== normalizeSpec(modelText);
    }

    function applyStoredMismatch(order) {
      if (!order) return order;
      const mismatch = isOrderSpecMismatch(order);
      const hasFixed = String(order.remark || "").includes("\u3010\u5df2\u8865\u5dee\u3011");
      const hasPending = String(order.remark || "").includes("\u3010\u5f85\u8865\u5dee\uff01\u3011");
      const withPendingRemark =
        mismatch && !hasFixed && !hasPending
          ? {
              ...order,
              remark: String(order.remark || "").trim()
                ? `${order.remark} \u3010\u5f85\u8865\u5dee\uff01\u3011`
                : "\u3010\u5f85\u8865\u5dee\uff01\u3011",
            }
          : order;
      if (mismatch && withPendingRemark.status === "stored") {
        return { ...withPendingRemark, status: "stored_mismatch" };
      }
      if (!mismatch && withPendingRemark.status === "stored_mismatch") {
        return { ...withPendingRemark, status: "stored" };
      }
      return withPendingRemark;
    }

    function applyActivationPendingRemark(order) {
      if (!order) return order;
      const activation = resolveActivation(order).label;
      if (activation !== "\u4ec5\u6fc0\u6d3b\uff08\u5f85\u8865\u5dee\uff09" && activation !== "\u9884\u6fc0\u6d3b\uff08\u5f85\u8865\u5dee\uff09") return order;
      const remark = String(order.remark || "").trim();
      if (
        remark.includes("\u3010\u5df2\u8865\u5dee\u3011") ||
        remark.includes("\u3010\u5f85\u8865\u5dee\uff01\u3011")
      ) {
        return order;
      }
      const nextRemark = remark
        ? `\u3010\u5f85\u8865\u5dee\uff01\u3011 ${remark}`
        : "\u3010\u5f85\u8865\u5dee\uff01\u3011";
      return {
        ...order,
        remark: nextRemark,
      };
    }

    function applyUnsignedRules(order) {
      if (!order || order.status !== "unsigned") return order;
      return {
        ...order,
        settle_price: "0",
      };
    }

    function applyOrderRules(order) {
      return applyStoredMismatch(applyActivationPendingRemark(applyRefundRules(applyUnsignedRules(order))));
    }

    function formatOrderDate(timestamp) {
      if (!timestamp) return "—";
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "—";
      const month = date.getMonth() + 1;
      const day = date.getDate();
      return `${month}月${day}日`;
    }

    function formatBillDate(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "--.--";
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${month}.${day}`;
    }

    function formatWeekday(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      const labels = ["周日", "周一", "周二", "周三", "周四", "周五", "周六"];
      return labels[date.getDay()];
    }

    function todayKey() {
      return formatOrderDate(getBeijingNow().getTime());
    }

    function formatDateInput(timestamp) {
      const date = new Date(timestamp || getBeijingNow().getTime());
      if (Number.isNaN(date.getTime())) return "";
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${date.getFullYear()}-${month}-${day}`;
    }

    function parseDateInput(value) {
      if (!value) return null;
      const parts = value.split("-");
      if (parts.length !== 3) return null;
      const year = Number(parts[0]);
      const month = Number(parts[1]);
      const day = Number(parts[2]);
      if (!year || !month || !day) return null;
      return new Date(year, month - 1, day).getTime();
    }

    function formatDateValue(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${date.getFullYear()}-${month}-${day}`;
    }

    function formatFilenameDate(timestamp) {
      return formatDateValue(timestamp || getBeijingNow().getTime()) || formatDateValue(getBeijingNow().getTime());
    }

    function formatFilenameDateRange(start, end) {
      const startText = start ? formatFilenameDate(start) : "";
      const endText = end ? formatFilenameDate(end) : "";
      if (startText && endText && startText !== endText) return `${startText}至${endText}`;
      if (startText) return startText;
      if (endText) return endText;
      return formatFilenameDate(getBeijingNow().getTime());
    }

    function getOrdersDateRange(list) {
      const times = (list || [])
        .map((order) => Number(order && order.createdAt))
        .filter((time) => Number.isFinite(time) && time > 0)
        .sort((a, b) => a - b);
      if (!times.length) {
        const today = getBeijingNow().getTime();
        return { start: today, end: today };
      }
      return { start: times[0], end: times[times.length - 1] };
    }

    function sanitizeFilenamePart(value) {
      return String(value || "")
        .trim()
        .replace(/[\\/:*?"<>|]+/g, "_")
        .replace(/\s+/g, "")
        .replace(/_+/g, "_") || "导出文件";
    }

    function buildExportFilename(content, suffix, options = {}) {
      const rangeText = options.rangeText || formatFilenameDateRange(options.start, options.end);
      const parts = [rangeText, content, options.scope].filter(Boolean).map(sanitizeFilenamePart);
      return `${parts.join("_")}${suffix}`;
    }

    function formatDateTime(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      const hour = String(date.getHours()).padStart(2, "0");
      const minute = String(date.getMinutes()).padStart(2, "0");
      return `${year}-${month}-${day} ${hour}:${minute}`;
    }

    function getBeijingNow() {
      const now = new Date();
      const utc = now.getTime() + now.getTimezoneOffset() * 60 * 1000;
      return new Date(utc + 8 * 60 * 60 * 1000);
    }

    function formatBeijingDateTime(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      const hour = String(date.getHours()).padStart(2, "0");
      const minute = String(date.getMinutes()).padStart(2, "0");
      return `${year}-${month}-${day} ${hour}:${minute}`;
    }

    function formatOperationLogTime(timestamp) {
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      const hour = String(date.getHours()).padStart(2, "0");
      const minute = String(date.getMinutes()).padStart(2, "0");
      const second = String(date.getSeconds()).padStart(2, "0");
      return `${year}-${month}-${day} ${hour}:${minute}:${second}`;
    }

    function getFilterValues() {
      return {
        name: readValue("filter_name").toLowerCase(),
        model: readValue("filter_model_select"),
        color: readValue("filter_color_select"),
        status: readValue("filter_status"),
        activation: readValue("filter_activation"),
        source: readValue("filter_source"),
        start: parseDateInput(readValue("filter_start")),
        end: parseDateInput(readValue("filter_end")),
      };
    }

    function getTableFilterValues() {
      return {
        name: readValue("table_filter_name").toLowerCase(),
        model: readValue("table_filter_model_select"),
        color: readValue("table_filter_color_select"),
        status: readValue("table_filter_status"),
        activation: readValue("table_filter_activation"),
        source: readValue("table_filter_source"),
        start: parseDateInput(readValue("table_filter_start")),
        end: parseDateInput(readValue("table_filter_end")),
      };
    }

    function getTableViewMeta(view = currentTableView) {
      if (view === "wanshun") {
        return { label: "对账表格-皖顺", source: "皖顺" };
      }
      if (view === "chengdu") {
        return { label: "对账表格-成都", source: "成都" };
      }
      return { label: "总表格", source: "" };
    }

    function shouldShowTableRunawayAmountColumn(view = currentTableView, filters = getTableFilterValues()) {
      return getTableViewMeta(view).source === "成都" || filters.source === "成都";
    }

    function getRunawayViewMeta(view = currentRunawayView) {
      if (view === "wanshun") {
        return {
          label: "跑路哥-皖顺",
          source: "皖顺",
          title: "跑路哥 - 皖顺",
          subtitle: "只显示皖顺来源的跑路订单。金额按“客户欠款/皖顺退我”两条线显示，金额列支持算式。",
          settleLabel: "已结算金额",
          takenLabel: "跑路金额",
          pendingCustomerLabel: "客户还欠金额",
          wanshunNeedLabel: "皖顺还差我金额",
          showWanshunNeed: true,
        };
      }
      if (view === "chengdu") {
        return {
          label: "跑路哥-成都",
          source: "成都",
          title: "跑路哥 - 成都",
          subtitle: "只显示成都来源的跑路订单。按当前筛选统计总跑路、已退回和当前还欠，不单列当月卡片。",
          settleLabel: "结算金额",
          takenLabel: "跑路金额",
          returnedLabel: "客户已退金额",
          pendingCustomerLabel: "客户还欠金额",
          statusLabel: "状态",
          wanshunNeedLabel: "",
          showWanshunNeed: false,
          showChengduFlow: true,
        };
      }
      return {
        label: "跑路哥",
        source: "",
        title: "跑路哥",
        subtitle: "数据来自总订单。金额按“客户已拿金额（跑路金额）/客户欠款/皖顺退我”两条线显示，金额列支持算式。",
        settleLabel: "结算金额",
        takenLabel: "跑路金额",
        pendingCustomerLabel: "客户还欠金额",
        wanshunNeedLabel: "",
        showWanshunNeed: false,
      };
    }

    function applyTableViewPreset(view = currentTableView) {
      currentTableView = view;
      const meta = getTableViewMeta(view);
      const sourceSelect = $("table_filter_source");
      if (sourceSelect) {
        sourceSelect.disabled = !!meta.source;
        sourceSelect.value = meta.source || "";
      }
      const subtitle = $("orderTableViewHint");
      if (subtitle) {
        subtitle.textContent = meta.source ? `当前固定来源：${meta.source}` : "当前显示全部来源订单";
      }
      ["table_filter_this_month", "table_filter_last_month"].forEach((id) => {
        const button = $(id);
        if (button) button.style.display = view === "all" ? "" : "none";
      });
    }

    function applyRunawayViewPreset(view = currentRunawayView) {
      currentRunawayView = view;
      const meta = getRunawayViewMeta(view);
      if ($("runawayTitle")) $("runawayTitle").textContent = meta.title;
      if ($("runawaySubtitle")) $("runawaySubtitle").textContent = meta.subtitle;
      if ($("runawayPanel")) $("runawayPanel").open = true;
      setRunawaySort("time", "desc", { syncSelect: true, render: false });
      if (view === "wanshun" || view === "chengdu") {
        setRunawayNavExpanded(true);
      }
    }

    function setRunawayNavExpanded(expanded) {
      const subNav = $("runawaySubNav");
      const arrow = $("runawayGroupArrow");
      if (subNav) subNav.classList.toggle("collapsed", !expanded);
      if (arrow) arrow.textContent = expanded ? "▾" : "▸";
    }

    function getRunawaySortSelectValue(field, dir) {
      if (field === "time") return dir === "asc" ? "time_asc" : "time_desc";
      return dir === "asc" ? "amount_asc" : "amount_desc";
    }

    function getRunawayViewSortValue(order, field) {
      const meta = getRunawayViewMeta();
      if (field === "time") return Number(order.createdAt) || 0;
      if (field === "settle") return parsePrice(order.settle_price);
      if (meta.showChengduFlow) {
        if (field === "taken") return getRunawayChengduTakenAmount(order);
        if (field === "returned") return getRunawayChengduReturnedAmount(order);
        if (field === "remain") return getRunawayChengduRemainAmount(order);
      } else {
        if (field === "taken") return getRunawayCustomerTakenAmount(order);
        if (field === "returned_customer") return getRunawayCustomerReturnedToWanShunAmount(order);
        if (field === "returned_me") return getRunawayCustomerReturnedToMeAmount(order);
        if (field === "total_returned") return getRunawayCustomerTotalReturnedAmount(order);
        if (field === "remain") return getRunawayCustomerRemainAmount(order);
        if (field === "wanshun_returned") return getRunawayWanshunReturnedToMeAmount(order);
        if (field === "wanshun_remain") return getRunawayWanshunRemainAmount(order);
      }
      return Number(order.createdAt) || 0;
    }

    function setRunawaySort(field, dir, options = {}) {
      currentRunawaySortField = field || "remain";
      currentRunawaySortDir = dir === "asc" ? "asc" : "desc";
      if (options.syncSelect !== false) {
        const select = $("runaway_sort");
        if (select) select.value = getRunawaySortSelectValue(currentRunawaySortField, currentRunawaySortDir);
      }
      if (options.render !== false) renderRunaway();
    }

    function runawaySortHeader(label, field) {
      const active = currentRunawaySortField === field;
      const icon = active ? (currentRunawaySortDir === "asc" ? "↑" : "↓") : "↕";
      return `<th><button type="button" class="th-sort${active ? " active" : ""}" data-runaway-sort-field="${escapeHtml(
        field
      )}"><span>${escapeHtml(label)}</span><span class="th-sort-icon">${icon}</span></button></th>`;
    }

    function isRunawayChengduView(view = currentRunawayView) {
      return view === "chengdu";
    }

    function getRunawayChengduTakenAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_amount);
      if (!parsed.hasValue) return 0;
      return parsed.value;
    }

    function getRunawayChengduReturnedAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_returned_amount);
      if (!parsed.hasValue) return 0;
      return parsed.value;
    }

    function getRunawayChengduRemainAmount(order) {
      return getRunawayChengduTakenAmount(order) - getRunawayChengduReturnedAmount(order);
    }

    function getRunawayChengduStatus(order) {
      return getRunawayChengduRemainAmount(order) > 0 ? "追回中" : "已结清";
    }

    function applyOrderFilter(list, options = {}) {
      const filters = options.filters || getFilterValues();
      const filterIds = Object.prototype.hasOwnProperty.call(options, "filterIds") ? options.filterIds : alertFilterIds;
      return list
        .filter((order) => {
        if (filterIds && !filterIds.has(order.id)) {
          return false;
        }
        if (filters.name) {
          const keyword = filters.name;
          const nameHit = String(order.seller_name || "").toLowerCase().includes(keyword);
          const idHit = String(order.id || "").toLowerCase().includes(keyword);
          const remarkHit = String(order.remark || "").toLowerCase().includes(keyword);
          const sfHit = String(order.sf_no || "").toLowerCase().includes(keyword);
          if (!nameHit && !idHit && !remarkHit && !sfHit) return false;
        }
        if (filters.model && order.model !== filters.model) return false;
        if (filters.color && order.color !== filters.color) return false;
        if (filters.status) {
          const statusValue = order.status || "";
          if (filters.status === "unsettled" || filters.status === "settled") {
            if (order.settlement !== filters.status) return false;
        } else if (filters.status === "not_stored") {
          if (statusValue === "stored" || statusValue === "stored_mismatch" || statusValue === "refunded") return false;
        } else if (statusValue !== filters.status) {
            return false;
          }
        }
        if (filters.activation) {
          const activation = resolveActivation(order).label;
          if (activation !== filters.activation) return false;
        }
        if (filters.source) {
          if (filters.source === "other") {
            if (!order.source || sources.includes(order.source)) return false;
          } else if (order.source !== filters.source) {
            return false;
          }
        }
        if (filters.start || filters.end) {
          const time = order.createdAt || 0;
          if (filters.start && time < filters.start) return false;
          if (filters.end) {
            const endTime = filters.end + 24 * 60 * 60 * 1000 - 1;
            if (time > endTime) return false;
          }
        }
        return true;
      })
      .sort((a, b) => (Number(b.createdAt) || 0) - (Number(a.createdAt) || 0));
    }

    function resolveActivation(order) {
      const raw = order?.activation ?? order?.activated ?? order?.isActivated ?? order?.active;
      if (raw === undefined || raw === null || raw === "") {
        return { label: "未激活", className: "inactive" };
      }
      if (typeof raw === "boolean") {
        return raw ? { label: "仅激活（直结）", className: "active-direct" } : { label: "未激活", className: "inactive" };
      }
      if (typeof raw === "number") {
        return raw ? { label: "仅激活（直结）", className: "active-direct" } : { label: "未激活", className: "inactive" };
      }
      const text = String(raw).trim();
      const lower = text.toLowerCase();
      const activeValues = new Set(["1", "true", "yes", "y", "active", "activated"]);
      const inactiveValues = new Set(["0", "false", "no", "n", "inactive"]);
       if (text.includes("预激活") && text.includes("待补差")) {
         return { label: "预激活（待补差）", className: "active-pending" };
       }
       if (text.includes("预激活") && text.includes("已补差")) {
         return { label: "预激活（已补差）", className: "active-fixed" };
       }
       if (text.includes("待补差")) {
         return { label: "仅激活（待补差）", className: "active-pending" };
       }
      if (text.includes("已补差")) {
        return { label: "仅激活（已补差）", className: "active-fixed" };
      }
       if (text === "预激活" || lower === "preactive" || lower === "pre-active") {
         return { label: "预激活", className: "pre-active" };
       }
       if (text === "预激活（直结）") {
         return { label: "预激活（直结）", className: "active-direct" };
       }
      if (text === "仅激活（直结）" || text === "已激活" || text === "仅激活" || text === "激活" || activeValues.has(lower)) {
        return { label: "仅激活（直结）", className: "active-direct" };
      }
      if (text === "未激活" || inactiveValues.has(lower)) {
        return { label: "未激活", className: "inactive" };
      }
      return { label: "未激活", className: "inactive" };
    }

    function isGapFixed(order) {
      const activation = resolveActivation(order).label;
       if (activation === "仅激活（已补差）" || activation === "预激活（已补差）") return true;
      const remark = String(order?.remark || "");
      return remark.includes("【已补差】");
    }

    function isGapPending(order) {
      if (isGapFixed(order)) return false;
      const activation = resolveActivation(order).label;
       if (activation === "仅激活（待补差）" || activation === "预激活（待补差）") return true;
      const remark = String(order?.remark || "");
      if (remark.includes("【待补差！】")) return true;
      return order?.status === "stored_mismatch";
    }

    function buildGapFilterIds(list, type) {
      const ids = list
        .filter((order) => (type === "fixed" ? isGapFixed(order) : isGapPending(order)))
        .map((order) => order.id);
      return new Set(ids);
    }

    function getSettlementSortValue(order) {
      const settlement = order?.settlement;
      if (settlement === "unsettled") return 0;
      if (settlement === "settled") return 1;
      return 2;
    }

    function getActivationSortValue(order) {
      const activation = resolveActivation(order).label;
       if (activation === "未激活") return 0;
       if (activation === "预激活") return 1;
       if (activation === "预激活（待补差）") return 2;
       if (activation === "仅激活（待补差）") return 3;
       if (activation === "预激活（已补差）") return 4;
       if (activation === "仅激活（已补差）") return 5;
       if (activation === "预激活（直结）") return 6;
       if (activation === "仅激活（直结）") return 7;
      return 9;
    }

    function getStatusSortValue(order) {
      const status = order?.status || "";
      const priority = ["unsigned", "signed", "group", "stored", "stored_mismatch", "runaway", "refunded"];
      const index = priority.indexOf(status);
      return index === -1 ? 99 : index;
    }

    function getStatusLabelHtml(order) {
      const label = String(orderStatusMap[order?.status] || order?.status || "--");
      if (order?.status === "stored_mismatch") {
        const prefix = "已入库";
        const marker = "型号不对";
        if (label.startsWith(prefix)) {
          const rest = label.slice(prefix.length);
          const idx = rest.indexOf(marker);
          if (idx >= 0) {
            const beforeMarker = rest.slice(0, idx);
            const afterMarker = rest.slice(idx + marker.length);
            return `<span class="status-prefix-green">${escapeHtml(prefix)}</span>${escapeHtml(beforeMarker)}<span class="status-suffix-warn">${escapeHtml(marker)}</span>${escapeHtml(afterMarker)}`;
          }
          return `<span class="status-prefix-green">${escapeHtml(prefix)}</span>${escapeHtml(rest)}`;
        }
      }
      return escapeHtml(label);
    }

    function updateSortButton(field, buttonId, iconId) {
      const button = $(buttonId);
      const icon = $(iconId);
      if (!button || !icon) return;
      if (tableSortField === field) {
        button.classList.add("active");
        icon.textContent = tableSortDir === "asc" ? "↑" : "↓";
      } else {
        button.classList.remove("active");
        icon.textContent = "↕";
      }
    }

    function updateTableSortIndicator() {
      updateSortButton("settlement", "table_sort_settlement", "table_sort_settlement_icon");
      updateSortButton("createdAt", "table_sort_time", "table_sort_time_icon");
      updateSortButton("activation", "table_sort_activation", "table_sort_activation_icon");
      updateSortButton("status", "table_sort_status", "table_sort_status_icon");
    }

    function orderCardHtml(order, options = {}) {
      const activation = resolveActivation(order);
      const remark = String(order.remark || "").trim();
      const remarkHtml = remark ? `<div class="order-remark">补差/备注：${formatRemarkText(remark)}</div>` : "";
      const actionsHtml = options.actionsHtml || "";
      return `
        <div class="order-main">
          <div class="order-header">
            <div>
              <div class="order-name">${escapeHtml(order.seller_name)}</div>
              <div class="order-meta">${escapeHtml(order.model || "未填写")}</div>
              <div class="order-submeta">${escapeHtml(order.memory || "未填写")}/${escapeHtml(order.color || "未填写")}/<span class="activation-status ${activation.className}">${activation.label}</span></div>
            </div>
            <div class="order-summary">
              <div class="order-amount"><span>结算价</span><span class="order-amount-value ${parsePrice(order.settle_price) > 0 ? activation.className : ""}">${escapeHtml(formatPrice(order.settle_price)) || "--"} 元</span></div>
              <div class="order-badges">
                ${
                  order.status === "refunded"
                    ? ""
                    : `<span class="order-badge ${
                        order.status === "stored" || order.status === "stored_mismatch"
                          ? "status-stored"
                          : order.status === "group"
                          ? "status-group"
                          : order.status === "refunded"
                          ? "status-refunded"
                          : order.status === "runaway"
                          ? "status-runaway"
                          : ""
                      }">${getStatusLabelHtml(order)}</span>`
                }
                <span class="order-badge settlement ${
                  order.status === "refunded" ? "refunded" : order.settlement === "unsettled" ? "unsettled" : ""
                }">${
                  order.status === "refunded"
                    ? "已退款"
                    : escapeHtml(orderSettlementMap[order.settlement] || order.settlement)
                }</span>
              </div>
            </div>
          </div>
          <div class="order-grid">
            ${remarkHtml}
            <div><span>回收价：</span>${escapeHtml(formatPrice(order.buy_price))} 元</div>
            <div><span>日期：</span>${escapeHtml(formatOrderDate(order.createdAt))}</div>
            <div class="order-grid-row">
              <div><span>来源：</span>${escapeHtml(order.source || "未填写")}</div>
              ${actionsHtml ? `<div class="order-actions-inline">${actionsHtml}</div>` : ""}
            </div>
          </div>
        </div>
      `;
    }

    function updateSelectedSummary() {
      const { paged: visibleOrders } = getPagedOrders();
      const total = visibleOrders.length;
      const selectedCount = selectedOrderIds.size;
      $("selectedCount").textContent = `已选 ${selectedCount} 单`;
      const selectAll = $("selectAllOrders");
      if (total === 0) {
        selectAll.checked = false;
        selectAll.indeterminate = false;
        updateTableSelectedSummary();
        return;
      }
      const selectedOnPage = visibleOrders.filter((order) => selectedOrderIds.has(order.id)).length;
      selectAll.checked = selectedOnPage === total;
      selectAll.indeterminate = selectedOnPage > 0 && selectedOnPage < total;
      updateTableSelectedSummary();
    }

    function updateTableSelectedSummary(visibleOrders = null) {
      const countEl = $("tableSelectedCount");
      const bulk = $("tableBulk");
      const selectAll = $("tableSelectAllOrders");
      const headerSelectAll = $("tableSelectAllHeader");
      const section = $("section-orders-table");
      const batchModeBtn = $("tableBatchModeBtn");
      if (!countEl || !selectAll || !headerSelectAll) return;
      if (section) {
        section.classList.toggle("table-batch-mode", tableBatchMode);
      }
      if (batchModeBtn) {
        batchModeBtn.textContent = tableBatchMode ? "退出批量" : "批量操作";
      }
      const tableOrders = visibleOrders || getTableFilteredOrders();
      countEl.textContent = `已选 ${selectedOrderIds.size} 单`;
      if (bulk) {
        bulk.style.display = tableBatchMode && tableOrders.length ? "flex" : "none";
      }
      if (!tableBatchMode) {
        selectAll.checked = false;
        selectAll.indeterminate = false;
        headerSelectAll.checked = false;
        headerSelectAll.indeterminate = false;
        return;
      }
      if (!tableOrders.length) {
        selectAll.checked = false;
        selectAll.indeterminate = false;
        headerSelectAll.checked = false;
        headerSelectAll.indeterminate = false;
        return;
      }
      const selectedInTable = tableOrders.filter((order) => selectedOrderIds.has(order.id)).length;
      const allChecked = selectedInTable === tableOrders.length;
      const indeterminate = selectedInTable > 0 && selectedInTable < tableOrders.length;
      selectAll.checked = allChecked;
      selectAll.indeterminate = indeterminate;
      headerSelectAll.checked = allChecked;
      headerSelectAll.indeterminate = indeterminate;
    }

    function setTableBatchMode(active, options = {}) {
      tableBatchMode = active;
      if (!active && options.clearSelection) {
        selectedOrderIds.clear();
      }
      renderOrderTable();
      updateSelectedSummary();
    }

    function getPagedOrders() {
      const visible = applyOrderFilter(orders);
      if (!usePagination) {
        return {
          visible,
          totalPages: 1,
          paged: visible,
        };
      }
      const totalPages = Math.max(1, Math.ceil(visible.length / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      const pageStart = (currentPage - 1) * pageSize;
      return {
        visible,
        totalPages,
        paged: visible.slice(pageStart, pageStart + pageSize),
      };
    }

    function renderOrders() {
      const list = $("orderList");
      list.innerHTML = "";
      const filters = getFilterValues();
      const signature = JSON.stringify(filters);
      if (signature !== lastFilterSignature) {
        selectedOrderIds.clear();
        currentPage = 1;
      }
      lastFilterSignature = signature;
      const { visible: visibleOrders, totalPages, paged: pagedOrders } = getPagedOrders();
      const nowTs = getBeijingNow().getTime();
      const startLabel = filters.start ? formatOrderDate(filters.start) : formatOrderDate(nowTs);
      const endLabel = filters.end ? formatOrderDate(filters.end) : formatOrderDate(nowTs);
      const storedCount = visibleOrders.filter(
        (order) => order.status === "stored" || order.status === "stored_mismatch"
      ).length;
      const notStoredCount = visibleOrders.filter(
        (order) => order.status !== "stored" && order.status !== "stored_mismatch" && order.status !== "refunded"
      ).length;
      $("orderListRange").textContent = `（${startLabel}-${endLabel}订单）`;
      $("orderListStats").innerHTML = `还有<span class="stat-number">${notStoredCount}</span>台未入库 已入库<span class="stat-number stored">${storedCount}</span>台`;
      $("orderCount").textContent = `共 ${visibleOrders.length} 单`;
      const pager = document.querySelector(".order-pagination");
      if (pager) {
        pager.style.display = usePagination ? "flex" : "none";
      }
      $("pageInfo").textContent = usePagination ? `第 ${currentPage} / ${totalPages} 页` : "全部";
      $("pagePrev").disabled = !usePagination || currentPage <= 1;
      $("pageNext").disabled = !usePagination || currentPage >= totalPages;
      $("orderEmpty").style.display = visibleOrders.length ? "none" : "block";
      $("orderBulk").style.display = visibleOrders.length ? "flex" : "none";
      const alertFilterClear = $("alertFilterClear");
      if (alertFilterClear) {
        alertFilterClear.style.display = alertFilterIds ? "inline-flex" : "none";
      }
      let changed = false;
      const grouped = pagedOrders.reduce((acc, order) => {
        const key = formatOrderDate(order.createdAt);
        if (!acc[key]) acc[key] = [];
        acc[key].push(order);
        return acc;
      }, {});
      const groupKeys = Object.keys(grouped).sort((a, b) => {
        const at = parseDateInput(a) || 0;
        const bt = parseDateInput(b) || 0;
        return bt - at;
      });
      const dateGroups = {};
      groupKeys.forEach((dateKey, groupIndex) => {
        dateGroups[dateKey] = grouped[dateKey].map((order) => order.id);
        const ids = dateGroups[dateKey];
        const allChecked = ids.length > 0 && ids.every((id) => selectedOrderIds.has(id));
        const anyChecked = ids.some((id) => selectedOrderIds.has(id));
        const groupDate = grouped[dateKey][0]?.createdAt;
        const weekdayLabel = groupDate ? formatWeekday(groupDate) : "";
        const dateCard = document.createElement("div");
        dateCard.className = "order-date-card";
        dateCard.style.setProperty("--delay", `${groupIndex * 0.05}s`);
        dateCard.innerHTML = `
          <label class="order-select-row">
            <input class="date-checkbox" type="checkbox" data-date="${dateKey}" ${allChecked ? "checked" : ""} data-indeterminate="${anyChecked && !allChecked ? "1" : ""}" />
            <span>${dateKey} ${weekdayLabel} 卡片订单</span>
          </label>
        `;
        list.appendChild(dateCard);
        grouped[dateKey].forEach((order, index) => {
        if (!order.color) {
          order.color = randomColorForModel(order.model);
          changed = true;
        }
        const card = document.createElement("div");
        card.className = `order-card status-${order.status || "signed"}`;
        card.dataset.id = order.id;
        card.style.setProperty("--delay", `${index * 0.05}s`);
        const actionsHtml = `
          <label class="order-select-row">
            <input class="order-checkbox" type="checkbox" data-action="select" ${selectedOrderIds.has(order.id) ? "checked" : ""} />
            <span>选择</span>
          </label>
          <button class="secondary" data-action="edit" type="button">编辑</button>
          <button class="danger" data-action="trash" type="button">删除</button>
        `;
        card.innerHTML = orderCardHtml(order, { actionsHtml });
        list.appendChild(card);
        });
      });
      list.dataset.dateGroups = JSON.stringify(dateGroups);
      if (changed) {
        saveOrders();
      }
      list.querySelectorAll("input.date-checkbox").forEach((checkbox) => {
        if (checkbox.dataset.indeterminate === "1") {
          checkbox.indeterminate = true;
        }
      });
      updateSelectedSummary();
      renderOrderTable();
      renderHome();
    }

    function renderOrderTable() {
      const body = $("orderTableBody");
      if (!body) return;
      const filters = getTableFilterValues();
      updateTableSortIndicator();
      const filteredOrders = getTableFilteredOrders();
      const visibleOrders = filteredOrders.slice().sort((a, b) => {
        if (tableSortField === "settlement") {
          const av = getSettlementSortValue(a);
          const bv = getSettlementSortValue(b);
          if (av !== bv) {
            return tableSortDir === "asc" ? av - bv : bv - av;
          }
        } else if (tableSortField === "createdAt") {
          const av = Number(a.createdAt) || 0;
          const bv = Number(b.createdAt) || 0;
          if (av !== bv) {
            return tableSortDir === "asc" ? av - bv : bv - av;
          }
        } else if (tableSortField === "activation") {
          const av = getActivationSortValue(a);
          const bv = getActivationSortValue(b);
          if (av !== bv) {
            return tableSortDir === "asc" ? av - bv : bv - av;
          }
        } else if (tableSortField === "status") {
          const av = getStatusSortValue(a);
          const bv = getStatusSortValue(b);
          if (av !== bv) {
            return tableSortDir === "asc" ? av - bv : bv - av;
          }
        }
        return (Number(b.createdAt) || 0) - (Number(a.createdAt) || 0);
      });
      const viewMeta = getTableViewMeta();
      const showRunawayAmount = viewMeta.source === "成都" || filters.source === "成都";
      let tableTitle = `${viewMeta.label}（全部订单）`;
      if (filters.start || filters.end) {
        const startLabel = filters.start ? formatOrderDate(filters.start) : "最早";
        const endLabel = filters.end ? formatOrderDate(filters.end) : "至今";
        tableTitle = `${viewMeta.label}（${startLabel}-${endLabel}）`;
      }
      $("orderTableTitle").textContent = tableTitle;
      $("tableOrderCount").textContent = `共${visibleOrders.length}单`;
      $("orderTableEmpty").style.display = visibleOrders.length ? "none" : "block";
      const runawayAmountHeader = $("table_runaway_amount_header");
      if (runawayAmountHeader) {
        runawayAmountHeader.style.display = showRunawayAmount ? "" : "none";
      }
      body.innerHTML = visibleOrders
        .map((order) => {
          const modelText = [order.model, order.memory, order.color].filter(Boolean).join(" ").trim() || "--";
          const actualText = String(order.actual_model_color || "").trim() || "--";
          const settlePrice = formatPrice(order.settle_price);
          const settlePriceText = settlePrice ? `${settlePrice} 元` : "--";
          const runawayAmountText = formatRunawayAmountHtml(order.runaway_amount, "is-green", "未填写");
          const activation = resolveActivation(order);
          const settlementLabel =
            order.status === "refunded" ? "已退款" : orderSettlementMap[order.settlement] || order.settlement || "--";
          const statusClass = String(order.status || "").replace(/[^a-z0-9_-]/gi, "");
          const settlementClass = String(order.settlement || "").replace(/[^a-z0-9_-]/gi, "");
          const sfText = String(order.sf_no || "").trim() || "--";
          return `
            <tr data-id="${escapeHtml(order.id || "")}">
              <td class="table-select-cell">
                <label class="order-select-row table-select-row" title="选择订单">
                  <input class="table-order-checkbox" type="checkbox" data-id="${escapeHtml(order.id || "")}" aria-label="选择订单 ${escapeHtml(order.id || "")}" ${
                    selectedOrderIds.has(order.id) ? "checked" : ""
                  } />
                </label>
              </td>
              <td><span class="table-id">${escapeHtml(order.id || "")}</span></td>
              <td data-field="source">${escapeHtml(order.source || "--")}</td>
              <td>${escapeHtml(formatDateValue(order.createdAt))}</td>
              <td data-field="seller_name">${escapeHtml(order.seller_name || "--")}</td>
              <td data-field="model_bundle">${escapeHtml(modelText)}</td>
              <td data-field="actual_model_color">${escapeHtml(actualText)}</td>
              <td data-field="activation"><span class="table-chip activation-${activation.className}">${escapeHtml(activation.label)}</span></td>
              <td data-field="settle_price">${escapeHtml(settlePriceText)}</td>
              <td data-field="runaway_amount" style="display:${showRunawayAmount ? "table-cell" : "none"};">${runawayAmountText}</td>
              <td data-field="status"><span class="table-chip status-${statusClass}">${getStatusLabelHtml(order)}</span></td>
              <td data-field="sf_no">${escapeHtml(sfText)}</td>
              <td data-field="remark">${formatRemarkText(order.remark || "")}</td>
              <td data-field="settlement"><span class="table-chip settlement-${settlementClass}">${escapeHtml(settlementLabel)}</span></td>
            </tr>
          `;
        })
        .join("");
      updateTableSelectedSummary(visibleOrders);
    }

    function getTableFilteredOrders() {
      return applyOrderFilter(orders, { filters: getTableFilterValues(), filterIds: tableFilterIds });
    }

    let lastUndo = null;
    let toastTimer = null;
    let fieldEditId = null;
    let fieldEditKey = "";

    function showSaveToast(undoPayload) {
      const toast = $("saveToast");
      const undoBtn = $("saveToastUndo");
      if (!toast || !undoBtn) return;
      if (toastTimer) clearTimeout(toastTimer);
      lastUndo = undoPayload || null;
      undoBtn.style.display = undoPayload ? "inline-flex" : "none";
      toast.classList.add("show");
      toastTimer = setTimeout(() => {
        toast.classList.remove("show");
      }, 3500);
    }

    function updateOrderById(orderId, changes, options = {}) {
      const idx = orders.findIndex((item) => item.id === orderId);
      if (idx === -1) return;
      const previous = { ...orders[idx] };
      const merged = { ...orders[idx], ...changes };
      orders[idx] = applyOrderRules(merged);
      saveOrders();
      renderOrders();
      if (!options.skipToast) {
        showSaveToast({ orderId, previous });
      }
    }

    function getActualModelColorOptions() {
      const modelList = models.length ? models : [...defaultModels];
      const memoryOptions = ["64G", "128G", "256G", "512G", "1TB", "2TB"];
      const options = [];
      modelList.forEach((model) => {
        const colors = modelColors[model] || [];
        colors.forEach((color) => {
          memoryOptions.forEach((memory) => {
            options.push(`${model} ${memory} ${color}`.trim());
          });
        });
      });
      return options;
    }

    function buildSelect(options, value, placeholder) {
      const select = document.createElement("select");
      if (placeholder !== undefined) {
        const empty = document.createElement("option");
        empty.value = "";
        empty.textContent = placeholder;
        select.appendChild(empty);
      }
      options.forEach((item) => {
        const option = document.createElement("option");
        option.value = item.value ?? item;
        option.textContent = item.label ?? item;
        select.appendChild(option);
      });
      if (value !== undefined && value !== null) {
        select.value = value;
      }
      return select;
    }

    function openFieldEditModal(order, field) {
      fieldEditId = order.id;
      fieldEditKey = field;
      $("fieldEditClear").style.display = "none";
      $("fieldEditNoDiff").style.display = "none";
      $("fieldEditClear").onclick = null;
      $("fieldEditNoDiff").onclick = null;
      const titleMap = {
        seller_name: "客户姓名",
        model_bundle: "型号颜色",
        actual_model_color: "实际入库型号",
        source: "订单来源",
        settle_price: "结算价格",
        runaway_amount: "跑路金额",
        runaway_returned_amount: "客户退皖顺金额",
        runaway_returned_to_me_amount: "客户退我金额",
        runaway_wanshun_returned_amount: "皖顺已退我金额",
        activation: "激活状态",
        settlement: "结算状态",
        status: "货物状态",
        sf_no: "顺丰单号",
      };
      if (isRunawayChengduView()) {
        titleMap.runaway_returned_amount = "客户已退金额";
      }
      const titleLabel = titleMap[field] || field;
      const orderNo = String(order?.id || "").trim();
      const prefix = orderNo ? `订单${orderNo} · ` : "";
      const nameText = (order?.seller_name || "未填写姓名").trim() || "未填写姓名";
      const modelText = [order?.model, order?.memory, order?.color].filter(Boolean).join(" ").trim() || "未填写机型";
      const statusText = orderStatusMap[order?.status] || order?.status || "未设置状态";
      $("fieldEditTitle").textContent = `编辑：${prefix}${titleLabel}（${nameText} · ${modelText} · ${statusText}）`;
      $("fieldEditHint").textContent = "只修改当前字段。";
      const formatFieldValue = (value) => {
        const text = String(value ?? "").trim();
        return text ? text : "空";
      };
      const confirmChange = (fromValue, toValue) =>
        confirm(`确认${titleLabel}的订单从“${formatFieldValue(fromValue)}”改到“${formatFieldValue(toValue)}”？`);
      const content = $("fieldEditContent");
      content.innerHTML = "";

      if (field === "model_bundle") {
        const modelList = models.length ? models : [...defaultModels];
        const modelSelect = buildSelect(modelList, order.model || "", "（请选择）");
        const memoryOptions = ["64G", "128G", "256G", "512G", "1TB", "2TB"];
        const memorySelect = buildSelect(memoryOptions, order.memory || "", "（请选择）");
        const colorSelect = document.createElement("select");

        const syncColors = (model, selected) => {
          const colors = model ? modelColors[model] || [] : [];
          colorSelect.innerHTML = "";
          const empty = document.createElement("option");
          empty.value = "";
          empty.textContent = colors.length ? "（请选择）" : "（请先选择机型）";
          colorSelect.appendChild(empty);
          colors.forEach((color) => {
            const option = document.createElement("option");
            option.value = color;
            option.textContent = color;
            colorSelect.appendChild(option);
          });
          if (selected && colors.includes(selected)) {
            colorSelect.value = selected;
          }
        };
        syncColors(order.model, order.color);
        modelSelect.addEventListener("change", () => {
          syncColors(modelSelect.value, "");
        });

        content.appendChild(modelSelect);
        content.appendChild(memorySelect);
        content.appendChild(colorSelect);
        $("fieldEditSave").onclick = () => {
          const model = modelSelect.value.trim();
          if (!model) {
            alert("请先选择机型");
            return;
          }
          const memory = memorySelect.value.trim();
          if (!memory) {
            alert("请先选择容量");
            return;
          }
          const color = colorSelect.value || randomColorForModel(model);
          const fromValue = [order.model, order.memory, order.color].filter(Boolean).join(" ").trim();
          const toValue = [model, memory, color].filter(Boolean).join(" ").trim();
          if (!confirmChange(fromValue, toValue)) return;
          updateOrderById(order.id, { model, memory, color });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      if (field === "actual_model_color") {
        const modelList = models.length ? models : [...defaultModels];
        const memoryOptions = ["64G", "128G", "256G", "512G", "1TB", "2TB"];
        const modelSelect = buildSelect(modelList, "", "（请选择机型）");
        const memorySelect = buildSelect(memoryOptions, "", "（请选择内存）");
        const colorSelect = document.createElement("select");

        const syncColors = (model, selected) => {
          const colors = model ? modelColors[model] || [] : [];
          colorSelect.innerHTML = "";
          const empty = document.createElement("option");
          empty.value = "";
          empty.textContent = colors.length ? "（请选择颜色）" : "（请先选择机型）";
          colorSelect.appendChild(empty);
          colors.forEach((color) => {
            const option = document.createElement("option");
            option.value = color;
            option.textContent = color;
            colorSelect.appendChild(option);
          });
          if (selected && colors.includes(selected)) {
            colorSelect.value = selected;
          }
        };

        const currentParts = String(order.actual_model_color || "").split(" ");
        if (currentParts.length >= 3) {
          modelSelect.value = currentParts[0];
          memorySelect.value = currentParts[1];
          syncColors(currentParts[0], currentParts.slice(2).join(" "));
        } else {
          syncColors(order.model || "", order.color || "");
          if (order.model) modelSelect.value = order.model;
          if (order.memory) memorySelect.value = order.memory;
        }

        modelSelect.addEventListener("change", () => {
          syncColors(modelSelect.value, "");
        });

        content.appendChild(modelSelect);
        content.appendChild(memorySelect);
        content.appendChild(colorSelect);
        $("fieldEditClear").style.display = "inline-flex";
        $("fieldEditClear").onclick = () => {
          if (!confirmChange(order.actual_model_color || "", "")) return;
          const changes = { actual_model_color: "" };
          if (order.status === "stored" || order.status === "stored_mismatch") {
            changes.status = "group";
          }
          updateOrderById(order.id, changes);
          closeModal("fieldEditModal");
        };
        $("fieldEditSave").onclick = () => {
          const model = modelSelect.value.trim();
          const memory = memorySelect.value.trim();
          const color = colorSelect.value.trim();
          if (!model || !memory || !color) {
            alert("请完整选择机型、内存、颜色");
            return;
          }
          const nextValue = `${model} ${memory} ${color}`.trim();
          if (!confirmChange(order.actual_model_color || "", nextValue)) return;
          updateOrderById(order.id, { actual_model_color: nextValue });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      if (field === "activation") {
        const options = [
          "未激活",
          "预激活",
          "预激活（直结）",
          "预激活（待补差）",
          "预激活（已补差）",
          "仅激活（直结）",
          "仅激活（待补差）",
          "仅激活（已补差）",
        ];
        const current = resolveActivation(order).label;
        const select = buildSelect(options, current, "（请选择）");
        content.appendChild(select);
        $("fieldEditSave").onclick = () => {
          if (!confirmChange(resolveActivation(order).label, select.value.trim())) return;
          updateOrderById(order.id, { activation: select.value.trim() });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      if (field === "settlement") {
        const options = Object.keys(orderSettlementMap).map((key) => ({
          value: key,
          label: orderSettlementMap[key],
        }));
        const select = buildSelect(options, order.settlement || "unsettled", "（请选择）");
        content.appendChild(select);
        $("fieldEditSave").onclick = () => {
          const fromLabel = orderSettlementMap[order.settlement || "unsettled"] || order.settlement || "";
          const toLabel = orderSettlementMap[select.value] || select.value;
          if (!confirmChange(fromLabel, toLabel)) return;
          updateOrderById(order.id, { settlement: select.value });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      if (field === "status") {
        const options = Object.keys(orderStatusMap).map((key) => ({
          value: key,
          label: orderStatusMap[key],
        }));
        const select = buildSelect(options, order.status || "signed", "（请选择）");
        content.appendChild(select);
        $("fieldEditSave").onclick = () => {
          const fromLabel = orderStatusMap[order.status || "signed"] || order.status || "";
          const toLabel = orderStatusMap[select.value] || select.value;
          if (!confirmChange(fromLabel, toLabel)) return;
          updateOrderById(order.id, { status: select.value });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      if (field === "source") {
        const options = (sources.length ? sources : [...defaultSources]).map((item) => ({ value: item, label: item }));
        const select = buildSelect(options, order.source || "", "（请选择）");
        content.appendChild(select);
        $("fieldEditSave").onclick = () => {
          if (!confirmChange(order.source || "", select.value.trim())) return;
          updateOrderById(order.id, { source: select.value.trim() });
          closeModal("fieldEditModal");
        };
        openModal("fieldEditModal");
        return;
      }

      const formulaFields = new Set([
        "runaway_amount",
        "runaway_returned_amount",
        "runaway_returned_to_me_amount",
        "runaway_wanshun_returned_amount",
      ]);
      const input = document.createElement("input");
      let control = input;
      if (field === "remark") {
        const textarea = document.createElement("textarea");
        textarea.value = order.remark || "";
        control = textarea;
        $("fieldEditNoDiff").style.display = "inline-flex";
        $("fieldEditNoDiff").onclick = () => {
          const prefix = "【已补差】无需补差";
          const current = control.value.trim();
          control.value = current.startsWith(prefix) ? current : `${prefix}${current ? " " + current : ""}`;
        };
      } else {
        input.type = field === "settle_price" ? "number" : "text";
        if (field === "settle_price") {
          input.min = "0";
        }
        input.value = order[field] || "";
      }
      content.appendChild(control);
      if (formulaFields.has(field)) {
        $("fieldEditClear").style.display = "inline-flex";
        $("fieldEditClear").onclick = () => {
          if (!confirmChange(order[field] || "", "")) return;
          updateOrderById(order.id, { [field]: "" });
          closeModal("fieldEditModal");
        };
        $("fieldEditHint").textContent =
          "支持直接填数字，也支持填写算式，例如 3000+6000=9000。系统按最终结果参与统计与合计。";
      } else {
        $("fieldEditHint").textContent = "只修改当前字段。";
      }
      $("fieldEditSave").onclick = () => {
        const value = control.value.trim();
        if (field === "settle_price") {
          const num = Number(value);
          if (!Number.isFinite(num) || num < 0) {
            alert("结算价格必须为有效数字");
            return;
          }
          if (!confirmChange(order.settle_price || "", value)) return;
          updateOrderById(order.id, { settle_price: value });
        } else if (formulaFields.has(field)) {
          const parsed = parseRunawayAmountFormula(value);
          if (value && !parsed.valid) {
            alert("金额格式不正确，请填写数字，或使用 3000+6000=9000 这种写法");
            return;
          }
          if (!confirmChange(order[field] || "", value)) return;
          updateOrderById(order.id, { [field]: value });
        } else {
          const changes = {};
          changes[field] = value;
          if (!confirmChange(order[field] || "", value)) return;
          updateOrderById(order.id, changes);
        }
        closeModal("fieldEditModal");
      };
      openModal("fieldEditModal");
    }

    function renderHome() {
      const today = todayKey();
      const todayOrders = orders.filter((order) => formatOrderDate(order.createdAt) === today);
      const pending = todayOrders.filter((order) => order.settlement === "unsettled");
      const now = getBeijingNow();
      const nowTs = now.getTime();
      const todayLabel = formatOrderDate(nowTs);
      const weekday = formatWeekday(nowTs);
      $("todayCount").innerHTML = `今日订单（${todayLabel} ${weekday} 一共 <span class="today-count-number">${pending.length}</span> 单待结算）`;
      $("todayEmpty").style.display = todayOrders.length ? "none" : "block";
      const list = $("todayList");
      list.innerHTML = "";
      todayOrders.forEach((order, index) => {
        const card = document.createElement("div");
        card.className = `order-card status-${order.status || "signed"}`;
        card.style.setProperty("--delay", `${index * 0.05}s`);
        card.innerHTML = orderCardHtml(order);
        list.appendChild(card);
      });
      const modelCounts = pending.reduce((acc, order) => {
        const color = order.color || "随机色";
        const key = `${order.model} ${order.memory} ${color}`.trim();
        acc[key] = (acc[key] || 0) + 1;
        return acc;
      }, {});
      const summary = $("todaySummary");
      summary.innerHTML = "";
      Object.keys(modelCounts).forEach((key) => {
        const item = document.createElement("div");
        item.innerHTML = `<span>待结算：</span>${escapeHtml(key)} · ${modelCounts[key]} 单`;
        summary.appendChild(item);
      });

      const weekStart = new Date(now);
      weekStart.setHours(0, 0, 0, 0);
      weekStart.setDate(weekStart.getDate() - 6);
      const weekEnd = new Date(now);
      weekEnd.setHours(23, 59, 59, 999);
      const weekOrders = orders.filter((order) => {
        const time = Number(order.createdAt) || 0;
        return time >= weekStart.getTime() && time <= weekEnd.getTime();
      });
      const weekStored = weekOrders.filter(
        (order) => order.status === "stored" || order.status === "stored_mismatch"
      ).length;
      const weekUnstored = weekOrders.filter(
        (order) => order.status !== "stored" && order.status !== "stored_mismatch" && order.status !== "refunded"
      ).length;
      const settledTotal = weekOrders.reduce((sum, order) => {
        if (order.settlement !== "settled") return sum;
        if (order.status === "stored" || order.status === "stored_mismatch" || order.status === "refunded") return sum;
        return sum + parsePrice(order.settle_price);
      }, 0);
      const weekCard = $("weekSummary");
      const weekStartLabel = formatOrderDate(weekStart.getTime());
      const weekEndLabel = formatOrderDate(weekEnd.getTime());
      weekCard.innerHTML = `
        <div class="card-title">近一周（${weekStartLabel}-${weekEndLabel}）订单</div>
        <div class="week-summary">
          <div class="week-line">
            一共<span class="week-number total">${weekOrders.length}</span>单
            已入库<span class="week-number stored">${weekStored}</span>台
            未入库<span class="week-number unstored">${weekUnstored}</span>台
          </div>
          <div class="week-line">
            已结算总价格<span class="week-number settled">${formatPrice(settledTotal)}</span>元
            <span style="color:var(--muted);font-size:12px;">（已入库的不算）</span>
          </div>
        </div>
      `;

      const alertList = $("alertList");
      const alertEmpty = $("alertEmpty");
      const alertTime = $("alertTime");
      const alertSelectedCount = $("alertSelectedCount");
      const updateAlertSelectedCount = () => {
        if (!alertSelectedCount || !alertList) return;
        const checked = alertList.querySelectorAll("input.alert-checkbox:checked").length;
        alertSelectedCount.textContent = `已选 ${checked} 条`;
      };
      if (alertTime) {
        alertTime.textContent = `系统时间（北京时间）：${formatBeijingDateTime(nowTs)}`;
      }
      const { groupSigned, groupUnstored, groupActivationPending, groupMismatch, groupStoredMissingActual } =
        buildAlertGroups(nowTs);
      if (alertList) {
        const blocks = [];
        const pushGroup = (title, list, typeClass, groupKey) => {
          if (!list.length) return;
          if (blocks.length) blocks.push('<div class="alert-divider"></div>');
          blocks.push(
            `<div class="alert-divider"><label><input class="alert-group-checkbox" type="checkbox" data-group="${escapeHtml(
              groupKey
            )}" /><span class="checkbox-box"></span><span>${escapeHtml(title)}</span></label></div>`
          );
          blocks.push(
            list
              .map((item) => {
                const typeHtml = String(item.type || "").replace(
                  /超(\d+)天/g,
                  '超 <span class="alert-days">$1</span> 天'
                );
                return `
                  <div class="alert-item">
                    <label class="alert-item-row">
                      <input class="alert-checkbox" type="checkbox" data-id="${escapeHtml(item.id)}" data-group="${escapeHtml(
                        groupKey
                      )}" />
                      <span class="checkbox-box"></span>
                      <span><strong class="${typeClass}">${typeHtml}</strong>：${escapeHtml(item.text)}</span>
                    </label>
                  </div>
                `;
              })
              .join("")
          );
        };
        pushGroup("下单后超3天未拉群", groupSigned, "alert-type-green", "signed");
        pushGroup("下单后超7天未入库", groupUnstored, "alert-type-yellow", "unstored");
        pushGroup("激活待补差", groupActivationPending, "alert-type-blue", "activation_pending");
        pushGroup("型号不对待补差", groupMismatch, "alert-type-blue", "mismatch");
        pushGroup("已入库未填实际型号", groupStoredMissingActual, "alert-type-yellow", "stored_missing");
        alertList.innerHTML = blocks.join("");
      }
      if (alertEmpty) {
      const hasAlerts =
        groupSigned.length ||
        groupUnstored.length ||
        groupActivationPending.length ||
        groupMismatch.length ||
        groupStoredMissingActual.length;
        alertEmpty.style.display = hasAlerts ? "none" : "block";
      }
      const alertActions = $("alertActions");
      if (alertActions) {
        const hasAlerts =
          groupSigned.length ||
          groupUnstored.length ||
          groupActivationPending.length ||
          groupMismatch.length ||
          groupStoredMissingActual.length;
        alertActions.style.display = hasAlerts ? "flex" : "none";
      }
      updateAlertSelectedCount();
      updateAlertCheckboxStates();
      renderRunaway();
    }

    function getRunawayOrders() {
      const source = getRunawayViewMeta().source;
      return orders
        .filter((order) => order.status === "runaway" && (!source || order.source === source))
        .sort((a, b) => (Number(b.createdAt) || 0) - (Number(a.createdAt) || 0));
    }

    function getRunawayFilteredOrders() {
      const start = parseDateInput(readValue("runaway_filter_start"));
      const end = parseDateInput(readValue("runaway_filter_end"));
      const sort = readValue("runaway_sort") || "time_desc";
      const sortMap =
        sort === "time_asc"
          ? { field: "time", dir: "asc" }
          : sort === "time_desc"
          ? { field: "time", dir: "desc" }
          : sort === "amount_asc"
          ? { field: "remain", dir: "asc" }
          : { field: "remain", dir: "desc" };
      if (currentRunawaySortField === "remain" || currentRunawaySortField === "time") {
        currentRunawaySortField = sortMap.field;
        currentRunawaySortDir = sortMap.dir;
      }
      const list = getRunawayOrders().filter((order) => {
        const time = Number(order.createdAt) || 0;
        if (start && time < start) return false;
        if (end) {
          const endTime = end + 24 * 60 * 60 * 1000 - 1;
          if (time > endTime) return false;
        }
        return true;
      });
      list.sort((a, b) => {
        const valueA = getRunawayViewSortValue(a, currentRunawaySortField);
        const valueB = getRunawayViewSortValue(b, currentRunawaySortField);
        const valueDiff = valueA - valueB;
        const timeDiff = (Number(a.createdAt) || 0) - (Number(b.createdAt) || 0);
        const dir = currentRunawaySortDir === "asc" ? 1 : -1;
        if (valueDiff) return dir * valueDiff;
        return currentRunawaySortDir === "asc" ? timeDiff : -timeDiff;
      });
      return list;
    }

    function parseRunawayAmountFormula(value) {
      const raw = String(value ?? "").trim();
      if (!raw) return { raw: "", value: 0, valid: true, hasValue: false, mode: "empty" };
      const compact = raw.replace(/,/g, "").replace(/\s+/g, "");
      const plainNumberPattern = /^-?\d+(?:\.\d+)?$/;
      if (compact.includes("=")) {
        const resultRaw = compact.split("=").pop();
        const result = Number(resultRaw);
        if (!Number.isFinite(result)) {
          return { raw, value: 0, valid: false, hasValue: true, mode: "equation" };
        }
        return { raw, value: result, valid: true, hasValue: true, mode: "equation" };
      }
      if (plainNumberPattern.test(compact)) {
        return { raw, value: Number(compact), valid: true, hasValue: true, mode: "number" };
      }
      if (/^[\d.+-]+$/.test(compact)) {
        const tokens = compact.match(/[+-]?\d+(?:\.\d+)?/g) || [];
        if (tokens.length && tokens.join("") === compact) {
          const total = tokens.reduce((sum, token) => sum + Number(token), 0);
          return { raw, value: total, valid: true, hasValue: true, mode: "expression" };
        }
      }
      return { raw, value: 0, valid: false, hasValue: true, mode: "invalid" };
    }

    function getRunawayAmountValue(order, field) {
      return parseRunawayAmountFormula(order?.[field]).value;
    }

    function getRunawayCustomerTakenAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_amount);
      if (!parsed.hasValue) return null;
      return parsed.value;
    }

    // 兼容旧数据：历史的 runaway_returned_amount 视为“客户退皖顺”
    function getRunawayCustomerReturnedToWanShunAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_returned_amount);
      // 需求：客户退皖顺默认为 0
      if (!parsed.hasValue) return 0;
      return parsed.value;
    }

    // 新增字段（仅写入订单 JSON，不改 SQLite 表结构）：客户直接退给我的金额
    function getRunawayCustomerReturnedToMeAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_returned_to_me_amount);
      // 需求：客户退我默认为 0
      if (!parsed.hasValue) return 0;
      return parsed.value;
    }

    function getRunawayWanshunReturnedToMeAmount(order) {
      const parsed = parseRunawayAmountFormula(order?.runaway_wanshun_returned_amount);
      if (!parsed.hasValue) return 0;
      return parsed.value;
    }

    function formatRunawayAmountHtml(value, toneClass, emptyText = "--") {
      const parsed = parseRunawayAmountFormula(value);
      if (!parsed.hasValue) {
        return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(emptyText)}</span>`;
      }
      if (!parsed.valid) {
        return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(parsed.raw || emptyText)}</span>`;
      }
      if (parsed.mode === "equation") {
        const eqIndex = parsed.raw.lastIndexOf("=");
        const left = parsed.raw.slice(0, eqIndex + 1);
        const right = parsed.raw.slice(eqIndex + 1).trim() || formatPrice(parsed.value);
        return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(left)}<span class="formula-result">${escapeHtml(right)}</span> 元</span>`;
      }
      if (parsed.mode === "expression") {
        return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(parsed.raw)}=<span class="formula-result">${escapeHtml(formatPrice(parsed.value))}</span> 元</span>`;
      }
      return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(parsed.raw)} 元</span>`;
    }

    function formatRunawayFormulaAmount(leftText, resultValue, toneClass, emptyText = "--") {
      if (!Number.isFinite(resultValue)) {
        return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(emptyText)}</span>`;
      }
      return `<span class="runaway-amount-cell ${toneClass}">${escapeHtml(leftText)}<span class="formula-result">${escapeHtml(formatPrice(resultValue))}</span> 元</span>`;
    }

    // 客户总已退 = 客户退皖顺 + 客户退我
    function getRunawayCustomerTotalReturnedAmount(order) {
      const toWanShun = getRunawayCustomerReturnedToWanShunAmount(order);
      const toMe = getRunawayCustomerReturnedToMeAmount(order);
      if (!Number.isFinite(toWanShun) && !Number.isFinite(toMe)) return null;
      return (Number.isFinite(toWanShun) ? toWanShun : 0) + (Number.isFinite(toMe) ? toMe : 0);
    }

    // 客户还欠 = 客户已拿 - 客户总已退
    function getRunawayCustomerRemainAmount(order) {
      const taken = getRunawayCustomerTakenAmount(order);
      const totalReturned = getRunawayCustomerTotalReturnedAmount(order);
      if (!Number.isFinite(taken) || !Number.isFinite(totalReturned)) return null;
      return taken - totalReturned;
    }

    // 皖顺还差我 = 已给皖顺结算 - 客户还欠金额 - 皖顺已退我
    function getRunawayWanshunRemainAmount(order) {
      const settledToWanShun = parsePrice(order?.settle_price);
      const customerRemain = getRunawayCustomerRemainAmount(order);
      const returned = getRunawayWanshunReturnedToMeAmount(order);
      if (!Number.isFinite(settledToWanShun) || !Number.isFinite(customerRemain) || !Number.isFinite(returned)) return null;
      return settledToWanShun - Math.max(customerRemain, 0) - returned;
    }

    function formatRunawayWanshunRemainText(value) {
      if (value === null || value === undefined) return "未填写";
      if (!Number.isFinite(value)) return "未填写";
      if (value > 0) return `${formatPrice(value)} 元`;
      if (value < 0) return `皖顺多退我：${formatPrice(Math.abs(value))} 元`;
      return "已结清";
    }

    function formatRunawayWanshunRemainHtml(value) {
      if (value === null || value === undefined || !Number.isFinite(value)) {
        return `<span class="runaway-amount-cell is-blue">未填写</span>`;
      }
      if (value > 0) {
        return `<span class="runaway-amount-cell is-blue"><span class="formula-result">${escapeHtml(
          formatPrice(value)
        )}</span> 元</span>`;
      }
      if (value < 0) {
        return `<span class="runaway-amount-cell is-green">皖顺多退我：<span class="formula-result">${escapeHtml(
          formatPrice(Math.abs(value))
        )}</span> 元</span>`;
      }
      return `<span class="runaway-amount-cell is-green">已结清</span>`;
    }

    function renderRunawayTableHead(meta) {
      if (!$("runawayTableHead")) return;
      if (meta.showChengduFlow) {
        $("runawayTableHead").innerHTML = [
          runawaySortHeader("订单时间", "time"),
