    function renderBatchModelPriceGroups() {
      const list = $("batchModelPriceList");
      const totalOrders = pendingModelPriceGroups.reduce((sum, group) => sum + group.orders.length, 0);
      $("batchModelPriceSummary").textContent = `共 ${totalOrders} 单，合并成 ${pendingModelPriceGroups.length} 个机型/激活类型价格。`;
      list.innerHTML = pendingModelPriceGroups
        .map((group) => {
          const names = group.orders
            .slice(0, 5)
            .map((order) => order.seller_name || "未填写姓名")
            .join("、");
          const extra = group.orders.length > 5 ? ` 等 ${group.orders.length} 单` : ` 共 ${group.orders.length} 单`;
          return `
            <label class="model-price-item">
              <div>
                <div class="model-price-title">
                  ${escapeHtml(group.label)} / <span class="activation-status ${group.activation.className}">${escapeHtml(group.activation.label)}</span>
                </div>
                <div class="model-price-note">${escapeHtml(names)}${escapeHtml(extra)}</div>
              </div>
              <input class="batch-model-price-input" data-key="${escapeHtml(group.key)}" type="number" min="0" placeholder="结算价" />
            </label>
          `;
        })
        .join("");
    }

    function applyBatchModelPrices() {
      if (!pendingModelPriceGroups.length) {
        closeBatchModelPriceModal();
        return;
      }
      const inputs = Array.from($("batchModelPriceList").querySelectorAll("input.batch-model-price-input"));
      const draftByGroup = new Map();
      for (const input of inputs) {
        const value = parsePrice(input.value);
        if (value <= 0) {
          alert("每个机型分组都需要填写有效结算价");
          input.focus();
          return;
        }
        draftByGroup.set(input.dataset.key, value);
      }
      const shouldSettle = confirm("是否同时更新为已结算状态？");
      const priceByOrderId = new Map();
      pendingModelPriceGroups.forEach((group) => {
        const price = draftByGroup.get(group.key);
        group.orders.forEach((order) => priceByOrderId.set(order.id, price));
      });
      orders = orders.map((order) => {
        if (!priceByOrderId.has(order.id)) return order;
        const next = { ...order, settle_price: priceByOrderId.get(order.id) };
        return shouldSettle ? { ...next, settlement: "settled" } : next;
      });
      pendingModelPriceGroups = [];
      selectedOrderIds.clear();
      saveOrders();
      renderOrders();
      closeModal("batchModelPriceModal");
    }

    function closeBatchModelPriceModal() {
      pendingModelPriceGroups = [];
      closeModal("batchModelPriceModal");
    }

