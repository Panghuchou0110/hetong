    function buildSettlementText(order) {
      const activation = resolveActivation(order);
      return [
        "【订单结算】",
        `客户：${order.seller_name}`,
        `机型：${order.model} ${order.memory}`,
        `颜色：${order.color || "未填写"}`,
        `激活：${activation.label}`,
        `回收价：${order.buy_price || "—"} 元`,
        `结算价：${order.settle_price || "—"} 元`,
        order.remark ? `补差/备注：${order.remark}` : "",
        `来源：${order.source || "未填写"}`,
