    function ensureConfigFromOrders() {
      const allOrders = orders.concat(trashedOrders);
      const orderModels = allOrders.map((order) => (order.model || "").trim()).filter((value) => value);
      const mergedModels = normalizeList([...models, ...orderModels]);
      let changed = mergedModels.length !== models.length;
      models = mergedModels;
      if (!modelColors || typeof modelColors !== "object") {
        modelColors = {};
        changed = true;
      }
      allOrders.forEach((order) => {
        const model = (order.model || "").trim();
        const color = (order.color || "").trim();
        if (!model) return;
        if (!modelColors[model]) {
          modelColors[model] = [];
          changed = true;
        }
        if (color && !modelColors[model].includes(color)) {
          modelColors[model].push(color);
          changed = true;
        }
      });
      if (changed) scheduleSaveState();
    }

