<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>回收订单管理系统</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --surface: rgba(255, 255, 255, 0.9);
      --surface-strong: rgba(255, 255, 255, 0.96);
      --surface-soft: rgba(15, 23, 42, 0.04);
      --text: #172033;
      --muted: #64748b;
      --border: rgba(15, 23, 42, 0.12);
      --accent: #38bdf8;
      --accent-hover: #2563eb;
      --accent-soft: rgba(14, 165, 233, 0.12);
      --success: #16a34a;
      --danger: #dc2626;
      --shadow: rgba(15, 23, 42, 0.12);
      --glow-blue: rgba(14, 165, 233, 0.14);
      --glow-purple: rgba(99, 102, 241, 0.12);
      --bg-spot-1: rgba(20, 184, 166, 0.12);
      --bg-spot-2: rgba(59, 130, 246, 0.14);
      --bg-spot-3: rgba(168, 85, 247, 0.1);
      --bg-grid: rgba(15, 23, 42, 0.035);
    }

    body.dark {
      --bg: #050b16;
      --surface: rgba(9, 18, 32, 0.78);
      --surface-strong: rgba(10, 20, 36, 0.94);
      --surface-soft: rgba(148, 163, 184, 0.08);
      --text: #dbe7f3;
      --muted: #8ea3b8;
      --border: rgba(148, 163, 184, 0.18);
      --accent: #38bdf8;
      --accent-hover: #a78bfa;
      --accent-soft: rgba(56, 189, 248, 0.16);
      --success: #34d399;
      --danger: #fb7185;
      --shadow: rgba(0, 0, 0, 0.42);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "IBM Plex Sans", "Noto Sans SC", "Source Han Sans SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      background:
        radial-gradient(920px 520px at 5% -10%, var(--bg-spot-2), transparent 62%),
        radial-gradient(780px 520px at 95% 8%, var(--bg-spot-3), transparent 62%),
        radial-gradient(760px 480px at 24% 115%, var(--bg-spot-1), transparent 60%),
        linear-gradient(145deg, #f8fbff 0%, #eef5ff 48%, #f5f7fb 100%);
      background-attachment: fixed;
    }

    body.dark {
      background:
        radial-gradient(920px 520px at 5% -10%, rgba(56, 189, 248, 0.22), transparent 62%),
        radial-gradient(780px 520px at 95% 8%, rgba(139, 92, 246, 0.2), transparent 62%),
        radial-gradient(760px 480px at 24% 115%, rgba(45, 212, 191, 0.18), transparent 60%),
        linear-gradient(145deg, #030712 0%, #071426 45%, #090d1a 100%);
      background-attachment: fixed;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    .particle-layer {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    .particle-layer::before,
    .particle-layer::after {
      content: "";
      position: absolute;
      inset: -20%;
      background-image:
        radial-gradient(2px 2px at 20% 30%, rgba(56, 189, 248, 0.35), transparent 50%),
        radial-gradient(1.5px 1.5px at 70% 20%, rgba(34, 197, 94, 0.35), transparent 50%),
        radial-gradient(2px 2px at 40% 80%, rgba(245, 158, 11, 0.3), transparent 50%),
        radial-gradient(1.5px 1.5px at 85% 70%, rgba(148, 163, 184, 0.35), transparent 50%),
        radial-gradient(1px 1px at 10% 60%, rgba(148, 163, 184, 0.3), transparent 50%);
      background-size: 220px 220px;
      animation: none;
    }

    .particle-layer::after {
      background-size: 260px 260px;
      animation-duration: 28s;
      opacity: 0.5;
      filter: blur(0.3px);
    }

    body::before {
      background:
        linear-gradient(transparent 0 23px, var(--bg-grid) 24px),
        linear-gradient(90deg, transparent 0 23px, var(--bg-grid) 24px);
      background-size: 24px 24px;
      opacity: 0.6;
      mask: radial-gradient(circle at 50% 20%, rgba(0, 0, 0, 0.7), transparent 70%);
    }

    body::after {
      background:
        linear-gradient(120deg, rgba(56, 189, 248, 0.08), transparent 30%, rgba(99, 102, 241, 0.07) 70%, transparent),
        radial-gradient(360px 240px at 80% 40%, rgba(45, 212, 191, 0.08), transparent 70%);
      filter: blur(2px);
      animation: none;
      opacity: 0.38;
    }

    @keyframes driftGlow {
      0% {
        transform: translate3d(0, 0, 0) scale(1);
      }
      50% {
        transform: translate3d(1.5%, -1%, 0) scale(1.02);
      }
      100% {
        transform: translate3d(-1%, 1.5%, 0) scale(1.03);
      }
    }

    @keyframes floatParticles {
      0% {
        transform: translate3d(0, 0, 0);
      }
      100% {
        transform: translate3d(-6%, 8%, 0);
      }
    }

    .app {
      position: relative;
    }

    .login-mask {
      position: relative;
      z-index: 2;
    }

    .login-mask {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at top left, rgba(9, 105, 218, 0.25), transparent 45%),
        radial-gradient(circle at bottom right, rgba(22, 163, 74, 0.22), transparent 50%),
        rgba(11, 15, 20, 0.75);
      z-index: 1000;
      padding: 16px;
    }

    body.locked .login-mask {
      display: flex;
    }

    .login-card {
      width: min(360px, 92vw);
      background: var(--surface-strong);
      border-radius: 14px;
      padding: 18px;
      border: 1px solid var(--border);
      box-shadow: 0 22px 60px rgba(0, 0, 0, 0.38), 0 0 36px rgba(56, 189, 248, 0.12);
      backdrop-filter: blur(18px);
    }

    .login-brand {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 1px;
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    .login-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .login-hint {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    .app {
      display: flex;
      min-height: 100vh;
    }

    body.locked .app {
      display: none;
    }

    .sidebar {
      width: 196px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(241, 246, 252, 0.92));
      border-right: 1px solid var(--border);
      padding: 20px 14px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      transition: width 0.2s ease, transform 0.2s ease;
      box-shadow: 16px 0 40px rgba(15, 23, 42, 0.1);
      backdrop-filter: blur(18px);
      z-index: 2;
    }

    body.dark .sidebar {
      background: linear-gradient(180deg, rgba(6, 14, 28, 0.96), rgba(8, 16, 30, 0.88));
      box-shadow: 16px 0 40px rgba(0, 0, 0, 0.28);
    }

    .sidebar.collapsed {
      width: 0;
      padding: 0;
      border-right: none;
      overflow: hidden;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      padding: 4px 2px 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    }

    .brand-mark {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, #22d3ee, #6366f1 58%, #a855f7);
      border: 1px solid rgba(255, 255, 255, 0.22);
      display: grid;
      place-items: center;
      font-size: 14px;
      font-weight: 700;
      color: #ffffff;
      flex-shrink: 0;
      box-shadow: 0 10px 26px rgba(56, 189, 248, 0.28);
    }

    body.dark .brand-mark {
      background: linear-gradient(135deg, #22d3ee, #6366f1 58%, #a855f7);
    }

    .brand-text {
      font-size: 12px;
      line-height: 1.2;
      white-space: normal;
      transition: opacity 0.2s ease;
      color: #1e293b;
      letter-spacing: 0.2px;
    }

    body.dark .brand-text {
      color: #e5eef8;
    }

    .sidebar.collapsed .brand-text {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .nav {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .nav button {
      border: 1px solid transparent;
      background: transparent;
      color: #475569;
      padding: 7px 8px;
      border-radius: 9px;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      font-size: 13px;
      text-align: left;
      transition: background 0.16s ease, border 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nav button:hover {
      background: rgba(14, 165, 233, 0.08);
      border-color: rgba(14, 165, 233, 0.18);
      color: #0f172a;
    }

    .nav button.active {
      background: linear-gradient(135deg, rgba(14, 165, 233, 0.18), rgba(37, 99, 235, 0.1));
      border-color: rgba(14, 165, 233, 0.32);
      color: #075985;
      font-weight: 600;
      box-shadow: inset 3px 0 0 rgba(14, 165, 233, 0.72), 0 8px 18px rgba(14, 165, 233, 0.1);
    }

    body.dark .nav button {
      color: #9fb1c5;
    }

    body.dark .nav button:hover {
      background: rgba(148, 163, 184, 0.08);
      border-color: rgba(148, 163, 184, 0.14);
      color: #e2ecf6;
    }

    body.dark .nav button.active {
      background: linear-gradient(135deg, rgba(14, 165, 233, 0.24), rgba(99, 102, 241, 0.28));
      border-color: rgba(125, 211, 252, 0.35);
      color: #ffffff;
    }

    .nav-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .group-toggle {
      justify-content: space-between;
      width: 100%;
    }

    .nav-sub {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding-left: 12px;
      border-left: 1px solid rgba(148, 163, 184, 0.12);
      margin-left: 14px;
    }

    .nav-sub.collapsed {
      display: none;
    }

    .nav-arrow {
      font-size: 12px;
      margin-left: auto;
      color: var(--muted);
    }

    .nav-icon {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: rgba(148, 163, 184, 0.08);
      border: 1px solid rgba(148, 163, 184, 0.12);
      display: grid;
      place-items: center;
      flex-shrink: 0;
      color: #64748b;
    }

    .nav-icon svg {
      width: 16px;
      height: 16px;
      display: block;
    }

    .nav-label {
      white-space: nowrap;
    }

    .nav button.active .nav-icon {
      background: rgba(14, 165, 233, 0.16);
      border-color: rgba(14, 165, 233, 0.26);
      color: #0284c7;
    }

    body.dark .nav button.active .nav-icon {
      background: rgba(255, 255, 255, 0.2);
      border-color: transparent;
      color: #ffffff;
    }

    body.dark .nav-icon {
      background: rgba(148, 163, 184, 0.08);
      color: #8ea3b8;
    }

    .sidebar.collapsed .nav-label,
    .sidebar.collapsed .nav-arrow {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .sidebar.collapsed * {
      pointer-events: none;
      visibility: hidden;
    }

    .sidebar.collapsed .sidebar-toggle {
      pointer-events: auto;
      visibility: visible;
    }

    .sidebar.collapsed .sidebar-toggle {
      position: fixed;
      left: 8px;
      top: 10px;
      z-index: 300;
      margin: 0;
      background: var(--surface-strong);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
    }

    .sidebar.collapsed .sidebar-toggle {
      justify-content: center;
    }

    .sidebar.collapsed .group-toggle {
      justify-content: center;
    }

    .sidebar.collapsed .sidebar-toggle * {
      visibility: visible;
      pointer-events: auto;
    }

    .sidebar-toggle {
      margin-top: auto;
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 6px 8px;
      background: rgba(148, 163, 184, 0.08);
      color: #475569;
      cursor: pointer;
      font-size: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    body.dark .sidebar-toggle {
      background: rgba(148, 163, 184, 0.08);
      color: #c7d6e6;
    }

    .sidebar.collapsed .toggle-text {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .main {
      flex: 1;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-width: 0;
      position: relative;
      z-index: 1;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 52px;
      padding: 10px 14px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 14px 40px rgba(15, 23, 42, 0.1);
      backdrop-filter: blur(18px);
    }

    body.dark .topbar {
      background: rgba(8, 17, 32, 0.7);
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.22);
    }

    .page-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .page-title {
      font-size: 22px;
      font-weight: 700;
      color: #172033;
      letter-spacing: 0.2px;
    }

    body.dark .page-title {
      color: #e5eef8;
    }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--muted);
      font-size: 12px;
      margin-left: auto;
    }

    #topbarGreeting {
      font-size: 14px;
      font-weight: 600;
      color: #334155;
      letter-spacing: 0.2px;
    }

    #topbarGreeting .greet-user {
      color: #0ea5e9;
      font-weight: 700;
    }

    #topbarGreeting .greet-date {
      color: #ef4444;
      font-weight: 700;
    }

    #topbarGreeting .greet-date-wrap {
      white-space: nowrap;
    }

    body.dark #topbarGreeting {
      color: #e2e8f0;
    }

    body.dark #topbarGreeting .greet-user {
      color: #7dd3fc;
    }

    body.dark #topbarGreeting .greet-date {
      color: #f87171;
    }

    .is-hidden {
      display: none !important;
    }

    .theme-toggle {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
      user-select: none;
      cursor: pointer;
      white-space: nowrap;
    }

    .theme-toggle input {
      width: 0;
      height: 0;
      opacity: 0;
      position: absolute;
    }

    .theme-slider {
      position: relative;
      width: 36px;
      height: 18px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      transition: background 0.2s ease;
      border: 1px solid rgba(148, 163, 184, 0.18);
    }

    .theme-slider::after {
      content: "";
      position: absolute;
      width: 14px;
      height: 14px;
      top: 2px;
      left: 2px;
      background: #ffffff;
      border-radius: 50%;
      transition: transform 0.2s ease;
      box-shadow: 0 1px 2px rgba(27, 31, 36, 0.2);
    }

    .theme-toggle input:checked + .theme-slider {
      background: linear-gradient(135deg, #22d3ee, #6366f1);
    }

    .theme-toggle input:checked + .theme-slider::after {
      transform: translateX(18px);
    }

    body.dark .theme-slider {
      background: #30363d;
    }

    #mobileMenu {
      display: none;
    }

    .section {
      display: none;
      animation: none;
    }

    .section.active {
      display: block;
    }

    .card {
      background: var(--surface);
      border-radius: 14px;
      padding: 14px 16px;
      border: 1px solid var(--border);
      box-shadow: 0 16px 42px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.8);
      position: relative;
      animation: none;
      backdrop-filter: blur(18px);
    }

    body.dark .card {
      box-shadow: 0 16px 42px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .section .card + .card {
      margin-top: 12px;
    }

    .quick-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      background:
        linear-gradient(135deg, rgba(14, 165, 233, 0.18), rgba(99, 102, 241, 0.12)),
        var(--surface);
    }

    .quick-bar .card-title {
      margin: 0;
    }

    .card-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 4px;
      color: var(--text);
      letter-spacing: 0.15px;
    }

    .card-subtitle {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px 10px;
    }

    #orderFilter,
    #tableFilter {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    label,
    .field-label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 600;
    }

    input, select, textarea {
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.92);
      color: var(--text);
      border-radius: 9px;
      padding: 8px 10px;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      transition: border 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    body.dark input,
    body.dark select,
    body.dark textarea {
      background: rgba(5, 12, 24, 0.64);
      color: var(--text);
    }

    body.dark select option {
      background: #071426;
      color: var(--text);
    }

    select option {
      background: #ffffff;
      color: #172033;
    }

    textarea {
      min-height: 120px;
      resize: vertical;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--accent);
      background: rgba(255, 255, 255, 0.98);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15), 0 0 24px rgba(56, 189, 248, 0.08);
    }

    body.dark input:focus,
    body.dark select:focus,
    body.dark textarea:focus {
      background: rgba(8, 18, 34, 0.82);
    }

    .field-error {
      color: var(--danger);
      font-size: 11px;
      min-height: 14px;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-top: 4px;
    }

    .button-row.align-right {
      justify-content: flex-end;
    }

    .range-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .range-row input {
      flex: 1;
    }

    .filter-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
    }

    .filter-arrow {
      font-size: 12px;
      color: var(--muted);
      transition: transform 0.2s ease;
    }

    .filter-collapsed #orderFilter {
      display: none;
    }

    .filter-collapsed .filter-arrow {
      transform: rotate(-90deg);
    }

    button {
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 7px 12px;
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      color: var(--text);
      transition: background 0.15s ease, border 0.15s ease, color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    button:hover:not(:disabled) {
      transform: translateY(-1px);
    }

    button.primary {
      background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 45%, #8b5cf6 100%);
      color: #fff;
      border-color: rgba(125, 211, 252, 0.42);
      box-shadow: 0 10px 24px rgba(37, 99, 235, 0.26);
    }

    button.primary:hover {
      background: linear-gradient(135deg, #5eead4 0%, #60a5fa 45%, #a78bfa 100%);
      border-color: rgba(125, 211, 252, 0.58);
      box-shadow: 0 14px 30px rgba(56, 189, 248, 0.28);
    }

    #btnParse {
      background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 55%, #0f172a 100%);
      border-color: transparent;
      box-shadow: 0 10px 24px rgba(37, 99, 235, 0.35);
      position: relative;
      overflow: hidden;
    }

    #btnParse::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 10%, rgba(255, 255, 255, 0.35) 50%, transparent 90%);
      transform: translateX(-120%);
      transition: transform 0.6s ease;
    }

    #btnParse:hover::after {
      transform: translateX(120%);
    }

    #btnOrderParse {
      background: linear-gradient(135deg, #22c55e 0%, #14b8a6 55%, #0f172a 100%);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 10px 24px rgba(20, 184, 166, 0.35);
      position: relative;
      overflow: hidden;
    }

    #btnOrderParse::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 10%, rgba(255, 255, 255, 0.35) 50%, transparent 90%);
      transform: translateX(-120%);
      transition: transform 0.6s ease;
    }

    #btnOrderParse:hover::after {
      transform: translateX(120%);
    }

    .contract-parse-actions {
      display: grid;
      grid-template-columns: 1fr 1.7fr;
      gap: 10px;
      width: 100%;
    }

    .contract-parse-actions button {
      width: 100%;
      min-height: 38px;
    }

    .filter-actions-right {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .runaway-controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 12px;
    }

