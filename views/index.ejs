    #safetyPasswordModal {
      background: rgba(15, 23, 42, 0.92);
    }

    body.dark #safetyPasswordModal {
      background: rgba(2, 6, 23, 0.92);
    }

    .modal-card {
      width: min(460px, 92vw);
      background: var(--surface-strong);
      border-radius: 14px;
      padding: 14px;
      border: 1px solid var(--border);
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.42), 0 0 34px rgba(56, 189, 248, 0.1);
      max-height: 86vh;
      overflow: auto;
      backdrop-filter: blur(18px);
    }

    .edit-modal-card {
      width: min(760px, 94vw);
      padding: 10px;
    }

    .edit-modal-card input,
    .edit-modal-card select,
    .edit-modal-card textarea {
      padding: 6px 8px;
      font-size: 12px;
    }

    .edit-modal-card .field {
      gap: 4px;
    }

    .edit-modal-card label {
      font-weight: 600;
      color: var(--muted);
    }

    body.dark .edit-modal-card label {
      color: #e2e8f0;
    }

    .modal-title {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .modal-text {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .modal-content {
      font-size: 12px;
      line-height: 1.6;
      background: rgba(255, 255, 255, 0.72);
      border-radius: 10px;
      padding: 8px;
      border: 1px solid var(--border);
      color: var(--text);
      margin-bottom: 10px;
      max-height: 260px;
      overflow: auto;
      white-space: pre-wrap;
    }

    body.dark .modal-content {
      background: rgba(5, 12, 24, 0.62);
      color: #e6edf3;
      border-color: var(--border);
    }

    .modal-actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      flex-wrap: wrap;
    }

    .edit-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      width: 100%;
    }

    .edit-section {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: rgba(148, 163, 184, 0.06);
      padding: 8px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    }

    .edit-section:last-of-type {
      grid-column: 1 / -1;
    }

    body.dark .edit-section {
      background: rgba(148, 163, 184, 0.06);
    }

    .edit-title {
      font-size: 12px;
      color: #334155;
      font-weight: 600;
      letter-spacing: 0.4px;
    }

    body.dark .edit-title {
      color: #e2e8f0;
    }


    .edit-body {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px 8px;
    }

    .edit-body .field {
      min-width: 0;
    }

    .edit-body .field:last-child {
      grid-column: 1 / -1;
    }

    .backdrop {
      display: none;
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes cardReveal {
      0% {
        transform: translateY(8px) scale(0.985);
        opacity: 0;
        box-shadow: 0 0 0 rgba(9, 105, 218, 0);
      }
      100% {
        transform: translateY(0) scale(1);
        opacity: 1;
        box-shadow: 0 10px 24px rgba(56, 189, 248, 0.18), 0 4px 10px var(--shadow);
      }
    }

    @keyframes pulseGlow {
      0%,
      100% {
        box-shadow: 0 4px 10px rgba(56, 189, 248, 0.12), 0 0 0 rgba(56, 189, 248, 0);
      }
      50% {
        box-shadow: 0 12px 28px rgba(56, 189, 248, 0.28), 0 0 22px rgba(34, 197, 94, 0.2);
      }
    }

    @media (max-width: 1024px) {
      .main {
        padding: 14px 16px 20px;
      }
    }

    @media (max-width: 900px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100%;
        transform: translateX(-100%);
        z-index: 200;
        width: min(82vw, 240px);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .backdrop {
        position: fixed;
        inset: 0;
        display: none;
        background: rgba(2, 6, 23, 0.62);
        z-index: 150;
        backdrop-filter: blur(6px);
      }

      .backdrop.show {
        display: block;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .runaway-risk-grid,
      .runaway-chart-grid {
        grid-template-columns: 1fr;
      }

      .runaway-risk-card,
      .runaway-risk-card.primary {
        grid-column: auto;
      }

      .runaway-panel > summary {
        padding: 14px 14px 12px;
      }

      .runaway-panel-body {
        padding: 0 14px 14px;
      }

      .runaway-bar-item {
        grid-template-columns: 84px minmax(0, 1fr) auto;
      }

      #mobileMenu {
        display: inline-flex;
      }
    }

    @media (max-width: 768px) {
      .main {
        padding: 12px;
      }

      .topbar,
      .card {
        border-radius: 12px;
      }

      .quick-bar {
        align-items: flex-start;
        flex-direction: column;
      }

      .week-summary {
        grid-template-columns: 1fr;
      }

      .runaway-risk-grid {
        gap: 10px;
      }

      .runaway-stat-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .runaway-panel-meta {
        justify-content: flex-start;
      }

      .runaway-progress-legend {
        grid-template-columns: 1fr;
      }

      .form-grid {
        grid-template-columns: 1fr;
      }

      #orderFilter {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #section-add .form-grid,
      #section-contract .form-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .order-list {
        grid-template-columns: 1fr;
      }

      .order-card {
        grid-template-columns: 1fr;
        padding: 6px 8px;
        gap: 6px;
      }

      .order-actions {
        justify-content: flex-end;
        width: 100%;
        margin-top: 2px;
      }

      .order-grid {
        grid-template-columns: 1fr;
        font-size: 12px;
        gap: 4px 8px;
      }

      .edit-grid {
        grid-template-columns: 1fr;
      }

      .edit-body {
        grid-template-columns: 1fr;
      }

      .edit-body .field:last-child {
        grid-column: auto;
      }

      .order-summary {
        align-items: flex-end;
        width: 100%;
      }

      .order-amount {
        font-size: 18px;
        width: auto;
        padding: 0;
        border-radius: 0;
        background: transparent;
        color: var(--text);
      }

      .order-badge {
        font-size: 13px;
        padding: 4px 10px;
      }

      .order-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        align-items: start;
        gap: 8px;
      }

      .order-badges {
        margin-top: 8px;
      }

      .order-summary {
        justify-self: end;
        width: 100%;
        max-width: 100%;
      }

      .order-pagination {

        justify-content: center;
      }

      .runaway-card-value.primary {
        font-size: 36px;
      }

      .runaway-card-value {
        font-size: 28px;
      }

      .order-date-card {
        padding: 5px 8px;
        font-size: 11px;
      }

      .order-select-row {
        font-size: 11px;
      }

      input:not([type="checkbox"]),
      select {
        min-height: 34px;
      }
    }

  </style>
</head>
