    function applyBatchSettle() {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      const missing = listMissingSettleOrders();
      if (missing.length) {
        alert(buildMissingSettleMessage(missing));
        return;
      }
      orders = orders.map((order) => {
        if (!selectedOrderIds.has(order.id)) return order;
        return { ...order, settlement: "settled" };
      });
      selectedOrderIds.clear();
      saveOrders();
      renderOrders();
    }

    function selectedOrderNames(limit = 12) {
      const selected = orders.filter((order) => selectedOrderIds.has(order.id));
      const lines = selected.slice(0, limit).map((order) => {
        const name = order.seller_name || "未填写姓名";
        const model = [order.model, order.memory, order.color].filter(Boolean).join(" ");
        return `${order.id || "--"} ${name} ${model}`.trim();
      });
      if (selected.length > limit) {
        lines.push(`另有 ${selected.length - limit} 单未展示`);
      }
      return { selected, text: lines.join("\n") };
    }

    function confirmBatchAction(actionText) {
      const { selected, text } = selectedOrderNames();
      if (!selected.length) {
        alert("请先选择订单");
        return false;
      }
      return confirm(`确认${actionText}以下 ${selected.length} 单？\n\n${text}`);
    }

    function applyBatchStatus(status) {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      orders = orders.map((order) => {
        if (!selectedOrderIds.has(order.id)) return order;
        return applyOrderRules({ ...order, status });
      });
      selectedOrderIds.clear();
      saveOrders();
      renderOrders();
    }

    function listMissingSettleOrders() {
      return orders.filter((order) => {
        if (!selectedOrderIds.has(order.id)) return false;
        if (order.status === "refunded") return false;
        if (order.status === "unsigned") return false;
        return parsePrice(order.settle_price) <= 0;
      });
    }

    function buildMissingSettleMessage(list) {
      const maxLines = 20;
      const lines = list.slice(0, maxLines).map((order, index) => {
        const name = order.seller_name || "未填写姓名";
        const model = order.model || "未填写机型";
        const memory = order.memory || "";
        const color = order.color || "";
        return `${index + 1}. ${name} - ${model} ${memory} ${color}`.trim();
      });
      const extra = list.length > maxLines ? `\n...另外还有 ${list.length - maxLines} 单未展示` : "";
      return `还有 ${list.length} 单未填写结算价，无法批量结算：\n` + lines.join("\n") + extra;
    }

