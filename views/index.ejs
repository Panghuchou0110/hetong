      const runawayToggle = $("runawayGroupToggle");
      if (runawayToggle) {
        runawayToggle.addEventListener("click", () => {
          const subNav = $("runawaySubNav");
          const isExpanded = !(subNav && subNav.classList.contains("collapsed"));
          setRunawayNavExpanded(!isExpanded);
        });
      }
      document.querySelectorAll(".nav button[data-target]").forEach((btn) => {
        btn.addEventListener("click", () => {
          if (btn.dataset.target === "section-orders-table") {
            applyTableViewPreset(btn.dataset.tableView || "all");
            renderOrderTable();
          }
          if (btn.dataset.target === "section-runaway") {
            applyRunawayViewPreset(btn.dataset.runawayView || "wanshun");
            renderRunaway();
          }
          updateSection(btn.dataset.target, btn.dataset.label || btn.innerText.trim());
          if (window.innerWidth <= 900) {
            $("sidebar").classList.remove("open");
            $("backdrop").classList.remove("show");
          }
        });
