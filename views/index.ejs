    async function verifyAdminPassword(password, options = {}) {
      const silent = !!options.silent;
      if (!password) {
        if (!silent) alert("请输入管理员密码");
        return false;
      }
      try {
        const response = await fetch("/api/admin/verify", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password }),
        });
        if (response.status === 401) {
          handleUnauthorized();
          return false;
        }
        if (!response.ok) {
          if (!silent) alert("管理员密码不正确");
          return false;
        }
        return true;
      } catch (err) {
        if (!silent) alert("验证失败");
        return false;
      }
    }

    async function confirmSafetyPassword() {
      const password = $("safetyPassword").value.trim();
      const ok = await verifyAdminPassword(password, { silent: pendingSafetySilent });
      if (!ok) {
        if (pendingSafetySilent) {
          $("safetyPassword").value = "";
        }
        return;
      }
      closeModal("safetyPasswordModal");
      const action = pendingSafetyAction;
      pendingSafetyAction = null;
      pendingSafetySilent = false;
      if (action) action();
    }

    function addSource(name) {
      const trimmed = (name || "").trim();
      if (!trimmed) {
        alert("请输入来源名称");
        return;
      }
      if (sources.includes(trimmed)) {
        alert("来源已存在");
        return;
      }
      sources.push(trimmed);
      saveSources();
      renderSourceSelects();
      renderSourceList();
      const input = $("source_name");
      if (input) input.value = "";
    }

    function deleteSource(name) {
      const inUse = orders.some((order) => order.source === name);
      if (inUse) {
        alert("已有订单使用该来源，无法删除");
        return;
      }
      sources = sources.filter((item) => item !== name);
      if (defaultSource === name) {
        defaultSource = "";
      }
      saveSources();
      renderSourceSelects();
      renderSourceList();
    }

    function moveSelectedToTrash() {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      const removed = [];
      orders = orders.filter((order) => {
        if (selectedOrderIds.has(order.id)) {
          removed.push(order);
          return false;
        }
        return true;
      });
      if (removed.length === 0) return;
      trashedOrders = removed.concat(trashedOrders);
      selectedOrderIds.clear();
      saveOrders();
      saveTrash();
      renderOrders();
      renderTrash();
    }

