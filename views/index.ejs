    $("editOrderForm").addEventListener("submit", (event) => {
      event.preventDefault();
      const data = collectOrderForm("edit");
      if (!validateOrder(data, "edit")) return;
      const idx = orders.findIndex((item) => item.id === editingId);
      if (idx !== -1) {
        const original = orders[idx];
        const nextSettlement = data.settlement || (data.settle_price ? "settled" : "unsettled");
        const nextDate = parseDateInput(data.order_date) || orders[idx].createdAt;
        const nameText = (data.seller_name || original.seller_name || "未填写姓名").trim() || "未填写姓名";
        const orderNo = String(original.id || "").trim();
        const changes = [];
        const pushChange = (label, fromValue, toValue) => {
          const fromText = formatConfirmValue(fromValue);
          const toText = formatConfirmValue(toValue);
          if (fromText === toText) return;
          changes.push(`${label}：${fromText} -> ${toText}`);
        };
        pushChange("客户姓名", original.seller_name, data.seller_name);
        pushChange("型号", original.model, data.model);
        pushChange("容量", original.memory, data.memory);
        pushChange("颜色", original.color, data.color);
        pushChange("实际入库型号", original.actual_model_color, data.actual_model_color);
        pushChange("顺丰单号", original.sf_no, data.sf_no);
        pushChange("回收价格", original.buy_price, data.buy_price);
        pushChange("结算价格", original.settle_price, data.settle_price);
        pushChange("订单来源", original.source, data.source);
        pushChange("订单状态", orderStatusMap[original.status] || original.status, orderStatusMap[data.status] || data.status);
        pushChange(
          "结算状态",
          orderSettlementMap[original.settlement || "unsettled"] || original.settlement,
          orderSettlementMap[nextSettlement] || nextSettlement
        );
        if (data.activation !== undefined) {
          pushChange("激活状态", resolveActivation(original).label, data.activation);
        }
        pushChange("订单日期", formatDateInput(original.createdAt), formatDateInput(nextDate));
        pushChange("补差/备注", original.remark, data.remark);
        const confirmLines = changes.length ? `\n${changes.map((item) => `- ${item}`).join("\n")}` : "";
        const confirmText = changes.length
          ? `确认保存订单${orderNo ? orderNo : ""}（${nameText}）的修改吗？${confirmLines}`
          : `未检测到修改，仍要保存订单${orderNo ? orderNo : ""}（${nameText}）吗？`;
        if (!confirm(confirmText)) return;
        const merged = { ...orders[idx], ...data, settlement: nextSettlement, createdAt: nextDate };
        orders[idx] = applyOrderRules(merged);
        saveOrders();
        renderOrders();
      }
      closeModal("editOrderModal");
    });

