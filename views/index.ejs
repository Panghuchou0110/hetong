    function updateAlertCheckboxStates() {
      const list = $("alertList");
      const countEl = $("alertSelectedCount");
      const selectAll = $("alertSelectAll");
      if (!list || !countEl || !selectAll) return;
      const items = Array.from(list.querySelectorAll("input.alert-checkbox"));
      const checkedItems = items.filter((el) => el.checked);
      countEl.textContent = `已选 ${checkedItems.length} 条`;
      if (items.length === 0) {
        selectAll.checked = false;
        selectAll.indeterminate = false;
      } else {
        selectAll.checked = checkedItems.length === items.length;
        selectAll.indeterminate = checkedItems.length > 0 && checkedItems.length < items.length;
      }
      const groupBoxes = Array.from(list.querySelectorAll("input.alert-group-checkbox"));
      groupBoxes.forEach((groupBox) => {
        const group = groupBox.dataset.group;
        const groupItems = items.filter((el) => el.dataset.group === group);
        const groupChecked = groupItems.filter((el) => el.checked).length;
        if (groupItems.length === 0) {
          groupBox.checked = false;
          groupBox.indeterminate = false;
        } else {
          groupBox.checked = groupChecked === groupItems.length;
          groupBox.indeterminate = groupChecked > 0 && groupChecked < groupItems.length;
        }
      });
    }

