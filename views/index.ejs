      const contractDate = parseDateInput(data.order_date) || getBeijingNow().getTime();
      const safeName = sanitizeFilenamePart(data.seller_name || "未命名");
      a.download = buildExportFilename(`${safeName}_买卖合同`, ".docx", { start: contractDate, end: contractDate });
      document.body.appendChild(a);
      a.click();
