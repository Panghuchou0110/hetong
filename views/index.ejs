      };
    }

    function validateContract(data) {
      if (!data.seller_name || !data.seller_id || !data.seller_phone) {
        alert("客户姓名/身份证/手机号不能为空");
        return false;
      }
      if (!/^[\u4e00-\u9fa5]{2,4}$/.test(data.seller_name)) {
        alert("客户姓名必须是2-4个中文字符");
        return false;
      }
      if (!isValidPhone(data.seller_phone)) {
        alert("手机号格式不正确");
        return false;
      }
      if (!isValidChineseId(data.seller_id)) {
        alert("身份证号格式不正确");
        return false;
      }
      if (!data.model) {
        alert("机型不能为空");
        return false;
      }
      if (!data.activation) {
        alert("是否激活未识别，请手动选择");
        return false;
      }
      if (!data.memory) {
        alert("容量不能为空");
        return false;
      }
      if (!data.color) {
        alert("未识别到有效颜色，请手动选择颜色");
        return false;
      }
      if (!data.price) {
        alert("回收价格不能为空");
        return false;
      }
      const priceValue = Number(data.price);
      if (!Number.isFinite(priceValue) || priceValue < 2000 || priceValue > 20000) {
        alert("回收价格必须在 2000-20000 之间");
        return false;
      }
      return true;
    }

