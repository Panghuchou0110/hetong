    function buildExportWorkbook(rows, columns, sheetName) {
      if (!window.XLSX) {
        alert("Excel 导出组件未加载，请检查网络或刷新页面");
        return null;
      }
      const header = columns.map((col) => col.label);
      const data = rows.map((row) => columns.map((col) => row[col.key] ?? ""));
      const sheet = window.XLSX.utils.aoa_to_sheet([header, ...data]);
      const measureText = (value) => {
        const text = String(value ?? "");
        let width = 0;
        for (const ch of text) {
          width += ch.charCodeAt(0) > 127 ? 2 : 1;
        }
        return width;
      };
      const autoWidths = columns.map((col) => {
        let max = measureText(col.label);
        rows.forEach((row) => {
          const cell = row[col.key] ?? "";
          const size = measureText(cell);
          if (size > max) max = size;
        });
        const padded = max + 2;
        return Math.min(40, Math.max(8, padded));
      });
      sheet["!cols"] = autoWidths.map((wch) => ({ wch }));
      sheet["!rows"] = [{ hpt: 24 }, ...data.map(() => ({ hpt: 20 }))];

      const headerStyle = {
        font: { bold: true, color: { rgb: "FFFFFF" } },
        fill: { fgColor: { rgb: "1F2937" } },
        alignment: { horizontal: "center", vertical: "center" },
      };
      const centerKeys = new Set(["activation", "status", "settlement"]);
      const rightKeys = new Set(["settle_price"]);
      const activationColors = {
        未激活: "6B7280",
        "预激活": "2563EB",
        "预激活（直结）": "2563EB",
        "预激活（待补差）": "F97316",
        "预激活（已补差）": "16A34A",
        "仅激活（直结）": "2563EB",
        "仅激活（待补差）": "F97316",
        "仅激活（已补差）": "16A34A",
      };
      const settlementColors = {
        已结算: "16A34A",
        未结算: "F97316",
        已退款: "6B7280",
      };
      const resolveStatusColor = (value) => {
        const text = String(value || "");
        if (text.includes("已补差")) return "16A34A";
        if (text.includes("型号不对")) return "F97316";
        if (text.includes("已入库")) return "16A34A";
        if (text.includes("已拉群")) return "2563EB";
        if (text.includes("已签")) return "0EA5E9";
        if (text.includes("未签")) return "6B7280";
        if (text.includes("已退款")) return "6B7280";
        if (text.includes("已跑路")) return "DC2626";
        return "";
      };
      const makeStyle = (key, value) => {
        const alignment = {
          vertical: "center",
          horizontal:
            typeof value === "number" && Number.isFinite(value)
              ? "right"
              : rightKeys.has(key)
              ? "right"
              : centerKeys.has(key)
              ? "center"
              : "left",
          wrapText: key === "remark" || key === "model_bundle" || key === "actual_model_color",
        };
        let color = "";
        if (key === "activation") color = activationColors[String(value || "")] || "";
        if (key === "settlement") color = settlementColors[String(value || "")] || "";
        if (key === "status") color = resolveStatusColor(value);
        const style = typeof value === "number" && Number.isFinite(value) ? { alignment, numFmt: "#,##0.##" } : { alignment };
        if (!color) return style;
        return { ...style, font: { color: { rgb: color }, bold: true } };
      };

      const totalCols = columns.length;
      for (let c = 0; c < totalCols; c += 1) {
        const cellRef = window.XLSX.utils.encode_cell({ r: 0, c });
        if (sheet[cellRef]) sheet[cellRef].s = headerStyle;
      }
      for (let r = 0; r < data.length; r += 1) {
        for (let c = 0; c < totalCols; c += 1) {
          const cellRef = window.XLSX.utils.encode_cell({ r: r + 1, c });
          if (!sheet[cellRef]) continue;
          const key = columns[c].key;
          sheet[cellRef].s = makeStyle(key, data[r][c]);
        }
      }

      const workbook = window.XLSX.utils.book_new();
      window.XLSX.utils.book_append_sheet(workbook, sheet, sheetName || "订单");
      return workbook;
    }

