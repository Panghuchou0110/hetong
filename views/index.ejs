  <script src="/vendor/xlsx-js-style/xlsx.bundle.js"></script>
  <script src="/vendor/jszip/jszip.min.js"></script>
  <script>
    const $ = (id) => document.getElementById(id);

    const orderStatusMap = {
      signed: "已签合同",
      group: "已拉群待入库",
      stored: "已入库",
      stored_mismatch: "已入库-型号不对",
      runaway: "已跑路",
      refunded: "已退款",
      unsigned: "未签合同",
    };

    const defaultSources = ["皖顺", "成都"];
    const defaultModels = [
      "iPhone 17 Pro Max",
      "iPhone 17 Pro",
      "iPhone 17",
      "iPhone 16 Pro Max",
      "iPhone 16 Pro",
      "iPhone 16",
    ];
    const defaultModelColors = {
      "iPhone 17 Pro Max": ["白色", "黑色", "原色"],
      "iPhone 17 Pro": ["白色", "黑色", "原色"],
      "iPhone 17": ["白色", "黑色", "原色"],
      "iPhone 16 Pro Max": ["白色", "黑色", "原色"],
      "iPhone 16 Pro": ["白色", "黑色", "原色"],
      "iPhone 16": ["白色", "黑色", "原色"],
    };
    let sources = [];
    let defaultSource = "皖顺";
    let authUsers = [];
    let authRememberHours = {};

    let models = [];
    let modelColors = {};

    const orderSettlementMap = {
      unsettled: "未结算",
      settled: "已结算",
    };
    const orderStatusReverseMap = Object.keys(orderStatusMap).reduce((acc, key) => {
      acc[orderStatusMap[key]] = key;
      return acc;
    }, {});
    const orderSettlementReverseMap = Object.keys(orderSettlementMap).reduce((acc, key) => {
      acc[orderSettlementMap[key]] = key;
      return acc;
    }, {});

    let allowedModels = new Set(defaultModels);


    let confirmed = false;
    let orders = [];
    let trashedOrders = [];
    let editingId = null;
    let pendingAddOrderResolve = null;
    let pendingExportText = "";
    let pendingDeleteId = null;
    let pendingDeleteAction = "";
    let pendingBatchStatus = "";
    let pendingSafetyAction = null;
    let pendingSafetySilent = false;
    let pendingPriceOrders = [];
    let pendingPriceIndex = 0;
    let pendingPriceDraft = new Map();
    let pendingModelPriceGroups = [];
    let lastFilterSignature = "";
    let selectedOrderIds = new Set();
    let alertFilterIds = null;
    let tableFilterIds = null;
    let tableSortField = "";
    let tableSortDir = "asc";
    let currentTableView = "all";
    let tableBatchMode = false;
    let batchExportSource = "orders";
    let currentRunawayView = "wanshun";
    let currentRunawaySortField = "remain";
    let currentRunawaySortDir = "desc";
    let trashUnlocked = false;
    let currentPage = 1;
    const pageSize = 25;
    const usePagination = false;
    let saveTimer = null;
    let saveInFlight = false;
    let savePending = false;
    let stateVersion = 0;
    let stateConflictShown = false;
    let operationLogs = [];
    let operationLogsLoaded = false;

    function buildDefaultState() {
      return {
        orders: [],
        trash: [],
        sources: [...defaultSources],
        defaultSource: "",
        models: [...defaultModels],
        modelColors: { ...defaultModelColors },
        authRememberHours: {},
      };
    }

    async function fetchState() {
      try {
        const response = await fetch("/api/state");
        if (response.status === 401) throw new Error("unauthorized");
        if (!response.ok) throw new Error("state_fetch_failed");
        const payload = await response.json();
        if (!payload || !payload.ok) throw new Error("state_fetch_failed");
        stateVersion = Number(payload.stateVersion ?? payload.state?.stateVersion ?? 0) || 0;
        return payload.state || buildDefaultState();
      } catch (err) {
        if (err && err.message === "unauthorized") {
          handleUnauthorized();
          return null;
        }
        console.error("state fetch failed", err);
        alert("读取订单数据失败，请刷新页面或检查服务器状态。为避免覆盖已有数据，本次不会进入空数据页面。");
        return null;
      }
    }

    async function persistState() {
      const payload = {
        orders,
        trash: trashedOrders,
        sources,
        defaultSource,
        models,
        modelColors,
        authRememberHours,
        stateVersion,
      };
      const response = await fetch("/api/state", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (response.status === 401) throw new Error("unauthorized");
      if (response.status === 409) {
        const result = await response.json().catch(() => ({}));
        const conflict = new Error(result && result.error ? result.error : "state_conflict");
        conflict.stateVersion = Number(result && result.stateVersion) || stateVersion;
        throw conflict;
      }
      if (!response.ok) throw new Error("state_save_failed");
      const result = await response.json();
      if (!result || !result.ok) throw new Error("state_save_failed");
      stateVersion = Number(result.stateVersion) || stateVersion;
      operationLogsLoaded = false;
    }

    function handleStateConflict() {
      if (stateConflictShown) return;
      stateConflictShown = true;
      alert("数据已被其他窗口或设备更新。为避免覆盖新数据，页面将刷新后重新加载最新订单。");
      window.location.reload();
    }

    function scheduleSaveState() {
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(async () => {
        if (saveInFlight) {
          savePending = true;
          return;
        }
        saveInFlight = true;
        try {
          await persistState();
        } catch (err) {
          if (err && err.message === "unauthorized") {
            handleUnauthorized();
          } else if (err && (err.message === "state_conflict" || err.message === "invalid_state_version")) {
            handleStateConflict();
          } else {
            console.error("state save failed", err);
          }
        } finally {
          saveInFlight = false;
          if (savePending) {
            savePending = false;
            scheduleSaveState();
          }
        }
      }, 350);
    }

    function saveOrders() {
      scheduleSaveState();
    }

    function saveSources() {
      scheduleSaveState();
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatRemarkText(remark) {
      const raw = String(remark || "");
      const tagPattern = /\u3010[^\u3011]+\u3011/g;
      const tags = raw.match(tagPattern) || [];
      const rest = raw.replace(tagPattern, "").trim();
      const ordered = `${tags.join(" ")}${tags.length && rest ? " " : ""}${rest}`.trim();
      const escaped = escapeHtml(ordered);
      return escaped
        .replace(/\u3010\u5f85\u8865\u5dee\uff01\u3011/g, '<span class="remark-tag pending">\u3010\u5f85\u8865\u5dee\uff01\u3011</span>')
        .replace(/\u3010\u5df2\u8865\u5dee\u3011/g, '<span class="remark-tag fixed">\u3010\u5df2\u8865\u5dee\u3011</span>');
    }

    function getAllColorsFromMap(map) {
      return Object.values(map || {}).reduce((acc, list) => acc.concat(list || []), []);
    }

    function getColorOptionsForModel(model) {
      if (!model) return [];
      return modelColors[model] || [];
    }

    function updateColorOptions(selectEl, model, selected) {
      if (!selectEl) return;
      const options = getColorOptionsForModel(model);
      selectEl.innerHTML = "";
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = options.length ? "（请选择）" : "（请先选择机型）";
      selectEl.appendChild(placeholder);
      options.forEach((color) => {
        const option = document.createElement("option");
        option.value = color;
        option.textContent = color;
        selectEl.appendChild(option);
      });
      if (selected && options.includes(selected)) {
        selectEl.value = selected;
      } else {
        selectEl.value = "";
      }
    }

    function randomColorForModel(model) {
      const options = getColorOptionsForModel(model);
      if (options.length === 0) return "";
      return options[Math.floor(Math.random() * options.length)];
    }

    function ensureColor(selectEl, model) {
      if (!selectEl) return;
      if (selectEl.value) return;
      const randomColor = randomColorForModel(model);
      if (randomColor) {
        selectEl.value = randomColor;
      }
    }

    function normalizeList(values) {
      return [...new Set(values.map((value) => (value || "").trim()).filter((value) => value))];
    }

    function getSeriesModels(model) {
      const label = String(model || "");
      if (label.includes("iPhone 17")) {
        return (models || []).filter((item) => String(item || "").includes("iPhone 17"));
      }
      if (label.includes("iPhone 16")) {
        return (models || []).filter((item) => String(item || "").includes("iPhone 16"));
      }
      return [model];
    }

    function ensureSourcesFromOrders() {
      const prevLength = Array.isArray(sources) ? sources.length : 0;
      const baseSources = Array.isArray(sources) && sources.length ? sources : [...defaultSources];
      const allOrders = orders.concat(trashedOrders);
      const orderSources = allOrders.map((order) => (order.source || "").trim()).filter((value) => value);
      const mergedSources = normalizeList([...baseSources, ...orderSources]);
      const changed = mergedSources.length !== prevLength;
      sources = mergedSources;
      if (changed) scheduleSaveState();
    }

    function renderSourceSelects() {
      const list = sources.length ? sources : [...defaultSources];
      const options = list
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      const applySelect = (selectEl, useDefault) => {
        if (!selectEl) return;
        const current = selectEl.value;
        const emptyOption = selectEl.querySelector('option[value=""]');
        const emptyLabel = emptyOption ? emptyOption.textContent : "";
        const otherOption = selectEl.querySelector('option[value="other"]');
        const otherLabel = otherOption ? otherOption.textContent : "other";
        let html = `<option value="">${escapeHtml(emptyLabel)}</option>` + options;
        if (otherOption) {
          html += `<option value="other">${escapeHtml(otherLabel)}</option>`;
        }
        if (current && !list.includes(current) && current !== "other") {
          html += `<option value="${escapeHtml(current)}">${escapeHtml(current)}</option>`;
        }
        selectEl.innerHTML = html;
        if (current) {
          selectEl.value = current;
          return;
        }
        if (useDefault && defaultSource && list.includes(defaultSource)) {
          selectEl.value = defaultSource;
        }
      };
      applySelect($("contractSource"), true);
      applySelect($("edit_source"), false);
      applySelect($("filter_source"), false);
      applySelect($("table_filter_source"), false);
      renderDefaultSourceSelect();
    }

    function renderSourceList() {
      renderConfigList($("sourceList"), sources || [], "暂无来源", "source");
    }

    function renderDefaultSourceSelect() {
      const selectEl = $("default_source");
      if (!selectEl) return;
      const list = sources.length ? sources : [...defaultSources];
      const options = list
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      selectEl.innerHTML = `<option value="">不设置</option>` + options;
      if (defaultSource && list.includes(defaultSource)) {
        selectEl.value = defaultSource;
        return;
      }
      if (defaultSource) {
        defaultSource = "";
        scheduleSaveState();
      }
      if (list.includes("皖顺")) {
        defaultSource = "皖顺";
        selectEl.value = "皖顺";
        scheduleSaveState();
        return;
      }
      selectEl.value = "";
    }

    function renderModelSelects() {
      const list = models.length ? models : [...defaultModels];
      allowedModels = new Set(list);
      const options = list
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      const applySelect = (selectEl, placeholderText) => {
        if (!selectEl) return;
        const current = selectEl.value;
        let html = `<option value="">${placeholderText}</option>` + options;
        if (current && !list.includes(current)) {
          html += `<option value="${escapeHtml(current)}">${escapeHtml(current)}</option>`;
        }
        selectEl.innerHTML = html;
        if (current) selectEl.value = current;
      };
      applySelect($("modelSelect"), "（自动识别/手动选择）");
      applySelect($("order_model"), "（请选择）");
      applySelect($("edit_model"), "（请选择）");
      applySelect($("filter_model_select"), "全部");
      applySelect($("table_filter_model_select"), "全部");
      renderColorModelSelect();
      renderActualModelColorSelects();
    }

    function renderColorModelSelect() {
      const selectEl = $("config_color_model");
      if (!selectEl) return;
      const list = models.length ? models : [...defaultModels];
      const current = selectEl.value;
      let html = `<option value="">（请选择机型）</option>` + list
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      selectEl.innerHTML = html;
      if (current && list.includes(current)) {
        selectEl.value = current;
      }
    }

    function renderActualModelColorSelects() {
      const modelList = models.length ? models : [...defaultModels];
      const memoryOptions = ["64G", "128G", "256G", "512G", "1TB", "2TB"];
      const pairs = [];
      modelList.forEach((model) => {
        const colors = modelColors[model] || [];
        if (!colors.length) return;
        colors.forEach((color) => {
          memoryOptions.forEach((memory) => {
            pairs.push(`${model} ${memory} ${color}`.trim());
          });
        });
      });
      const options = pairs
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      const applySelect = (selectEl) => {
        if (!selectEl) return;
        const current = selectEl.value;
        let html = `<option value="">（可选）</option>` + options;
        if (current && !pairs.includes(current)) {
          html += `<option value="${escapeHtml(current)}">${escapeHtml(current)}</option>`;
        }
        selectEl.innerHTML = html;
        if (current) selectEl.value = current;
      };
      applySelect($("edit_actual_model_color"));
    }

    function renderColorFilterSelect() {
      const list = normalizeList(getAllColorsFromMap(modelColors));
      let html = `<option value="">全部</option>` + list
        .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        .join("");
      const applySelect = (selectEl) => {
        if (!selectEl) return;
        const current = selectEl.value;
        let nextHtml = html;
        if (current && !list.includes(current)) {
          nextHtml += `<option value="${escapeHtml(current)}">${escapeHtml(current)}</option>`;
        }
        selectEl.innerHTML = nextHtml;
        if (current) selectEl.value = current;
      };
      applySelect($("filter_color_select"));
      applySelect($("table_filter_color_select"));
    }

    function renderConfigList(listEl, items, emptyText, dataKey) {
      if (!listEl) return;
      listEl.innerHTML = "";
      if (!items.length) {
        const empty = document.createElement("div");
        empty.className = "empty-state";
        empty.textContent = emptyText;
        listEl.appendChild(empty);
        return;
      }
      items.forEach((value) => {
        const chip = document.createElement("div");
        chip.className = "source-chip";
        const label = document.createElement("span");
        label.textContent = value;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.dataset[dataKey] = value;
        btn.textContent = "删除";
        chip.appendChild(label);
        chip.appendChild(btn);
        listEl.appendChild(chip);
      });
    }

    function renderAuthUsers() {
      const listEl = $("authUserList");
      if (!listEl) return;
      listEl.innerHTML = "";
      const currentUser = getCurrentLoginUser() || (loginUser ? loginUser.value.trim() : "");
      const names = [...new Set(authUsers.map((item) => item.username || "").concat(currentUser).filter((name) => name))];
      if (!names.length) {
        const empty = document.createElement("div");
        empty.className = "empty-state";
        empty.textContent = "\u6682\u65e0\u8d26\u53f7";
        listEl.appendChild(empty);
        return;
      }
      names.forEach((name) => {
        const chip = document.createElement("div");
        chip.className = "source-chip";
        const label = document.createElement("span");
        label.textContent = name;
        chip.appendChild(label);
        const rememberSelect = document.createElement("select");
        rememberSelect.dataset.rememberUser = name;
        rememberSelect.style.maxWidth = "120px";
        [24, 36, 48].forEach((hours) => {
          const option = document.createElement("option");
          option.value = String(hours);
          option.textContent = `${hours}小时`;
          rememberSelect.appendChild(option);
        });
        rememberSelect.value = String(Number(authRememberHours[name]) || 24);
        chip.appendChild(rememberSelect);
        if (name !== "admin") {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.dataset.authuser = name;
          btn.textContent = "\u5220\u9664";
          chip.appendChild(btn);
        } else {
          const tag = document.createElement("span");
          tag.textContent = "\uff08\u8d85\u7ea7\u7ba1\u7406\u5458\uff09";
          tag.style.color = "var(--muted)";
          tag.style.fontSize = "12px";
          chip.appendChild(tag);
        }
        listEl.appendChild(chip);
      });
    }

    async function fetchAuthUsers() {
      try {
        const response = await fetch("/api/auth/users");
        if (response.status === 401) {
          handleUnauthorized();
          return;
        }
        const result = await response.json();
        if (!response.ok || !result.ok) throw new Error("load_failed");
        authUsers = Array.isArray(result.users) ? result.users : [];
      } catch (err) {
        authUsers = [];
      }
      renderAuthUsers();
    }

    function setAuthRememberHours(user, hours) {
      const name = String(user || "").trim();
      const value = Number(hours);
      if (!name || ![24, 36, 48].includes(value)) return;
      authRememberHours = { ...authRememberHours, [name]: value };
      scheduleSaveState();
      renderAuthUsers();
    }

    async function addAuthUser(user, pass) {
      const name = (user || "").trim();
      const password = String(pass || "");
      if (!name || !password) {
        alert("\u8bf7\u8f93\u5165\u8d26\u53f7\u548c\u5bc6\u7801");
        return;
      }
      try {
        const response = await fetch("/api/auth/users", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ user: name, pass: password }),
        });
        if (response.status === 401) {
          handleUnauthorized();
          return;
        }
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          const msgMap = {
            user_exists: "\u8d26\u53f7\u5df2\u5b58\u5728",
            user_reserved: "\u8be5\u8d26\u53f7\u7531\u73af\u5883\u53d8\u91cf\u914d\u7f6e\uff0c\u65e0\u6cd5\u6dfb\u52a0",
            admin_required: "\u8bf7\u5148\u901a\u8fc7\u7ba1\u7406\u5458\u9a8c\u8bc1",
          };
          alert(msgMap[result.error] || "\u6dfb\u52a0\u5931\u8d25");
          return;
        }
        $("auth_user_name").value = "";
        $("auth_user_pass").value = "";
        await fetchAuthUsers();
      } catch (err) {
        alert("\u6dfb\u52a0\u5931\u8d25");
      }
    }

    async function deleteAuthUser(user) {
      const name = (user || "").trim();
      if (name === "admin") {
        alert("\u8d85\u7ea7\u7ba1\u7406\u5458\u8d26\u53f7\u4e0d\u5141\u8bb8\u5220\u9664");
        return;
      }
      if (!name) return;
      try {
        const response = await fetch("/api/auth/users", {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ user: name }),
        });
        if (response.status === 401) {
          handleUnauthorized();
          return;
        }
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          const msgMap = {
            user_reserved: "\u8be5\u8d26\u53f7\u7531\u73af\u5883\u53d8\u91cf\u914d\u7f6e\uff0c\u65e0\u6cd5\u5220\u9664",
            user_protected: "\u8d85\u7ea7\u7ba1\u7406\u5458\u8d26\u53f7\u4e0d\u5141\u8bb8\u5220\u9664",
            admin_required: "\u8bf7\u5148\u901a\u8fc7\u7ba1\u7406\u5458\u9a8c\u8bc1",
          };
          alert(msgMap[result.error] || "\u5220\u9664\u5931\u8d25");
          return;
        }
        await fetchAuthUsers();
      } catch (err) {
        alert("\u5220\u9664\u5931\u8d25");
      }
    }

    function getCurrentLoginUser() {
      const saved = localStorage.getItem("remember_login");
      if (!saved) return "";
      try {
        const { user } = JSON.parse(saved);
        return String(user || "").trim();
      } catch (err) {
        return "";
      }
    }

    function isAdminAccount() {
      const user = getCurrentLoginUser() || loginUser.value.trim();
      return user === "admin";
    }

    function updateAccountManagementVisibility() {
      const card = $("accountManagementCard");
      if (!card) return;
      const isAdmin = isAdminAccount();
      card.classList.toggle("is-hidden", !isAdmin);
      if (isAdmin) {
        fetchAuthUsers();
      } else {
        authUsers = [];
        renderAuthUsers();
      }
    }

    function formatChineseDateParts(date) {
      const days = ["日", "一", "二", "三", "四", "五", "六"];
      const year = date.getFullYear();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      const weekday = `周${days[date.getDay()]}`;
      return { year, month, day, weekday };
    }

    function updateTopbarGreeting() {
      const el = $("topbarGreeting");
      if (!el) return;
      const homeActive = $("section-home") && $("section-home").classList.contains("active");
      el.classList.toggle("is-hidden", !homeActive);
      if (!homeActive) return;
      const user = getCurrentLoginUser() || loginUser.value.trim() || "用户";
      const { year, month, day, weekday } = formatChineseDateParts(getBeijingNow());
      el.innerHTML = `您好: <span class="greet-user">${escapeHtml(user)}</span>，<span class="greet-date-wrap">今天是${year}年<span class="greet-date">${month}</span>月<span class="greet-date">${day}</span>日 ${weekday}</span>`;
    }

    async function changeAuthPassword(user, oldPass, newPass, confirmPass) {
      const targetUser = String(user || "").trim();
      const currentUser = getCurrentLoginUser();
      if (!targetUser) {
        alert("\u8bf7\u8f93\u5165\u8d26\u53f7");
        return;
      }
      if (!currentUser) {
        alert("\u8bf7\u5148\u767b\u5f55\u540e\u518d\u4fee\u6539\u5bc6\u7801");
        return;
      }
      if (targetUser !== currentUser) {
        alert("\u53ea\u80fd\u4fee\u6539\u5f53\u524d\u767b\u5f55\u8d26\u53f7\u7684\u5bc6\u7801");
        return;
      }
      if (!oldPass || !newPass) {
        alert("\u8bf7\u8f93\u5165\u5b8c\u6574\u7684\u5bc6\u7801\u4fe1\u606f");
        return;
      }
      if (newPass !== confirmPass) {
        alert("\u4e24\u6b21\u8f93\u5165\u7684\u65b0\u5bc6\u7801\u4e0d\u4e00\u81f4");
        return;
      }
      if (!confirm("\u786e\u5b9a\u8981\u4fee\u6539\u5bc6\u7801\u5417\uff1f")) {
        return;
      }
      try {
        const response = await fetch("/api/auth/password", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ user: targetUser, oldPass, newPass }),
        });
        if (response.status === 401) {
          handleUnauthorized();
          return;
        }
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          const msgMap = {
            invalid_credentials: "\u539f\u5bc6\u7801\u9519\u8bef",
            user_reserved: "\u8be5\u8d26\u53f7\u7531\u73af\u5883\u53d8\u91cf\u914d\u7f6e\uff0c\u65e0\u6cd5\u5728\u9875\u9762\u4e2d\u4fee\u6539",
            user_mismatch: "\u53ea\u80fd\u4fee\u6539\u5f53\u524d\u767b\u5f55\u8d26\u53f7\u7684\u5bc6\u7801",
          };
          alert(msgMap[result.error] || "\u4fee\u6539\u5931\u8d25");
          return;
        }
        $("auth_change_user").value = "";
        $("auth_old_pass").value = "";
        $("auth_new_pass").value = "";
        $("auth_new_pass_confirm").value = "";
        alert("\u5bc6\u7801\u5df2\u66f4\u65b0");
      } catch (err) {
        alert("\u4fee\u6539\u5931\u8d25");
      }
    }

