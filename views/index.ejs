          "<th>客户姓名</th>",
          "<th>手机型号</th>",
          runawaySortHeader(meta.takenLabel, "taken"),
          runawaySortHeader(meta.returnedLabel, "returned"),
          runawaySortHeader(meta.pendingCustomerLabel, "remain"),
          "<th>状态</th>",
          "<th>备注</th>",
        ].join("");
        return;
      }
      const columns = meta.showWanshunNeed
        ? [
            runawaySortHeader("订单时间", "time"),
            "<th>订单来源</th>",
            "<th>客户姓名</th>",
            "<th>手机型号</th>",
            runawaySortHeader(meta.settleLabel, "settle"),
            runawaySortHeader(meta.takenLabel, "taken"),
            runawaySortHeader("客户退皖顺", "returned_customer"),
            runawaySortHeader("客户退我", "returned_me"),
            runawaySortHeader("客户总退（自动）", "total_returned"),
            runawaySortHeader("客户还欠（自动）", "remain"),
            runawaySortHeader("皖顺已退我", "wanshun_returned"),
            runawaySortHeader("皖顺还差我（自动）", "wanshun_remain"),
            "<th>备注</th>",
          ]
        : [
            runawaySortHeader("订单时间", "time"),
            "<th>订单来源</th>",
            "<th>客户姓名</th>",
            "<th>手机型号</th>",
            runawaySortHeader(meta.settleLabel, "settle"),
            runawaySortHeader(meta.takenLabel, "taken"),
            runawaySortHeader("客户退皖顺", "returned_customer"),
            runawaySortHeader("客户退我", "returned_me"),
            runawaySortHeader("客户总退（自动）", "total_returned"),
            runawaySortHeader("客户还欠（自动）", "remain"),
            "<th>备注</th>",
          ];
      $("runawayTableHead").innerHTML = columns.join("");
    }

    function runawayRowHtml(order) {
      const meta = getRunawayViewMeta();
      const device = [order.model, order.memory, order.color].filter(Boolean).join(" ") || "未填写手机";
      const sourceText = String(order.source || "未填写");
      const settleAmount = formatPrice(order.settle_price) || "--";
      if (meta.showChengduFlow) {
        const remainAmount = getRunawayChengduRemainAmount(order);
        const statusLabel = getRunawayChengduStatus(order);
        const remarkText = formatRemarkPlain(order.remark || "") || "--";
        const remainHtml =
          remainAmount > 0
            ? `<span class="runaway-amount-cell is-yellow"><span class="formula-result">${escapeHtml(formatPrice(remainAmount))}</span> 元</span>`
            : `<span class="runaway-amount-cell is-green">已结清</span>`;
        const statusHtml =
          statusLabel === "追回中"
            ? `<span class="runaway-status-cell is-yellow">追回中</span>`
            : `<span class="runaway-status-cell is-green">已结清</span>`;
        return `
        <tr data-id="${escapeHtml(order.id || "")}">
          <td>${escapeHtml(formatDateValue(order.createdAt))}</td>
          <td>${escapeHtml(sourceText)}</td>
          <td class="name-cell">${escapeHtml(order.seller_name || "未填写姓名")}</td>
          <td>${escapeHtml(device)}</td>
          <td data-field="runaway_amount">${formatRunawayAmountHtml(order.runaway_amount, "is-red", "0")}</td>
          <td data-field="runaway_returned_amount">${formatRunawayAmountHtml(order.runaway_returned_amount, "is-green", "0")}</td>
          <td>${remainHtml}</td>
          <td>${statusHtml}</td>
          <td data-field="remark">${escapeHtml(remarkText)}</td>
        </tr>
      `;
      }
      const customerTotalReturned = getRunawayCustomerTotalReturnedAmount(order);
      const customerRemain = getRunawayCustomerRemainAmount(order);
      const wanshunReturned = getRunawayWanshunReturnedToMeAmount(order);
      const wanshunRemain = getRunawayWanshunRemainAmount(order);

      const formatClearing = (value, toneClass) => {
        if (value === null || value === undefined) return `<span class="runaway-amount-cell ${toneClass}">未填写</span>`;
        if (!Number.isFinite(value)) return `<span class="runaway-amount-cell ${toneClass}">未填写</span>`;
        if (value <= 0) return `<span class="runaway-amount-cell ${toneClass}">已结清</span>`;
        return `<span class="runaway-amount-cell ${toneClass}"><span class="formula-result">${escapeHtml(
          formatPrice(value)
        )}</span> 元</span>`;
      };

      const formatZeroAsNumber = (value, toneClass) => {
        if (value === null || value === undefined) return `<span class="runaway-amount-cell ${toneClass}">未填写</span>`;
        if (!Number.isFinite(value)) return `<span class="runaway-amount-cell ${toneClass}">未填写</span>`;
        if (value === 0) return `<span class="runaway-amount-cell ${toneClass}">0</span>`;
        return `<span class="runaway-amount-cell ${toneClass}"><span class="formula-result">${escapeHtml(
          formatPrice(value)
        )}</span> 元</span>`;
      };

      const customerTotalReturnedHtml =
        customerTotalReturned === null
          ? `<span class="runaway-amount-cell is-green">未填写</span>`
          : formatZeroAsNumber(customerTotalReturned, "is-green");

      const customerRemainHtml =
        customerRemain === null ? `<span class="runaway-amount-cell is-yellow">未填写</span>` : formatClearing(customerRemain, "is-yellow");
      const remarkText = formatRemarkPlain(order.remark || "") || "--";

      const wanshunReturnedHtml =
        meta.showWanshunNeed
          ? formatRunawayAmountHtml(order.runaway_wanshun_returned_amount, "is-green", "0").replace(">--<", ">0<")
          : "";

      const wanshunRemainHtml =
        meta.showWanshunNeed
          ? formatRunawayWanshunRemainHtml(wanshunRemain)
          : "";
      return `
        <tr data-id="${escapeHtml(order.id || "")}">
          <td>${escapeHtml(formatDateValue(order.createdAt))}</td>
          <td>${escapeHtml(sourceText)}</td>
          <td class="name-cell">${escapeHtml(order.seller_name || "未填写姓名")}</td>
          <td>${escapeHtml(device)}</td>
          <td data-field="settle_price">${escapeHtml(settleAmount)} 元</td>
          <td data-field="runaway_amount">${formatRunawayAmountHtml(order.runaway_amount, "is-red", "未填写")}</td>
          <td data-field="runaway_returned_amount">${formatRunawayAmountHtml(order.runaway_returned_amount, "is-green", "0")}</td>
          <td data-field="runaway_returned_to_me_amount">${formatRunawayAmountHtml(order.runaway_returned_to_me_amount, "is-green", "0")}</td>
          <td>${customerTotalReturnedHtml}</td>
          <td>${customerRemainHtml}</td>
          ${meta.showWanshunNeed ? `<td data-field="runaway_wanshun_returned_amount">${wanshunReturnedHtml}</td>` : ""}
          ${meta.showWanshunNeed ? `<td>${wanshunRemainHtml}</td>` : ""}
          <td data-field="remark">${escapeHtml(remarkText)}</td>
        </tr>
      `;
    }

    function renderRunaway() {
      const meta = getRunawayViewMeta();
      const list = getRunawayFilteredOrders();
      const settled = list.reduce((sum, order) => sum + parsePrice(order.settle_price), 0);
      const customerTaken = meta.showChengduFlow
        ? list.reduce((sum, order) => sum + getRunawayChengduTakenAmount(order), 0)
        : list.reduce((sum, order) => {
            const v = getRunawayCustomerTakenAmount(order);
            return Number.isFinite(v) ? sum + v : sum;
          }, 0);
      const customerTotalReturned = meta.showChengduFlow
        ? list.reduce((sum, order) => sum + getRunawayChengduReturnedAmount(order), 0)
        : list.reduce((sum, order) => {
            const v = getRunawayCustomerTotalReturnedAmount(order);
            return Number.isFinite(v) ? sum + v : sum;
          }, 0);
      const customerRemainTotal = meta.showChengduFlow
        ? list.reduce((sum, order) => sum + getRunawayChengduRemainAmount(order), 0)
        : list.reduce((sum, order) => {
            const v = getRunawayCustomerRemainAmount(order);
            return Number.isFinite(v) ? sum + v : sum;
          }, 0);
      const wanshunReturnedTotal = meta.showChengduFlow
        ? 0
        : list.reduce((sum, order) => {
            const v = getRunawayWanshunReturnedToMeAmount(order);
            return Number.isFinite(v) ? sum + v : sum;
          }, 0);
      const wanshunRemainTotal = meta.showChengduFlow
        ? 0
        : list.reduce((sum, order) => {
            const v = getRunawayWanshunRemainAmount(order);
            return Number.isFinite(v) ? sum + v : sum;
          }, 0);
      if ($("runawayCount")) $("runawayCount").textContent = `共 ${list.length} 单`;
      renderRunawayTableHead(meta);
      const cleanRunawaySummaryHtml = (html) => String(html || "").replace(/undefined/g, "");
      if ($("runawaySummary")) {
        if (meta.showWanshunNeed) {
          const wanshunRiskAmount = Math.max(wanshunRemainTotal, 0);
          const runawayAmountTotal = Math.max(customerTaken, 0);
          const customerRiskAmount = Math.max(customerRemainTotal, 0);
          const wanshunRefundedAmount = Math.max(wanshunReturnedTotal, 0);
          const refundNeedTotal = wanshunRefundedAmount + wanshunRiskAmount;
          const riskItems = [
            { label: "皖顺还没退回", value: wanshunRiskAmount, tone: "danger" },
            { label: "总共跑路", value: runawayAmountTotal, tone: "alt" },
            { label: "客户还没要回", value: customerRiskAmount, tone: "good" },
          ];
          const riskMax = Math.max(...riskItems.map((item) => item.value), 1);
          const statItems = [
            { label: "跑路订单数", value: `${list.length} 单` },
            { label: "结算总额", value: `${formatPrice(settled)} 元` },
            { label: "客户已退总额", value: `${formatPrice(customerTotalReturned)} 元` },
            { label: "皖顺已退我总额", value: `${formatPrice(wanshunRefundedAmount)} 元` },
          ];
          const chartBars = riskItems
            .map((item) => {
              const width = `${(item.value / riskMax) * 100}%`;
              return `
                <div class="runaway-bar-item">
                  <div class="runaway-bar-label">${escapeHtml(item.label)}</div>
                  <div class="runaway-bar-track"><div class="runaway-bar-fill ${item.tone}" style="width:${width};"></div></div>
                  <div class="runaway-bar-value">${escapeHtml(formatPrice(item.value))} 元</div>
                </div>
              `;
            })
            .join("");
          const refundPaidPct = refundNeedTotal > 0 ? (wanshunRefundedAmount / refundNeedTotal) * 100 : 0;
          const refundRemainPct = refundNeedTotal > 0 ? (wanshunRiskAmount / refundNeedTotal) * 100 : 0;
          const chartHtml = `
            <div class="runaway-dashboard">
