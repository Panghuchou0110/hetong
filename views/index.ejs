    function openBatchBill() {
      if (selectedOrderIds.size === 0) {
        alert("请先选择订单");
        return;
      }
      if (!confirmBatchAction("生成结算账单")) return;
      const selected = orders.filter((order) => selectedOrderIds.has(order.id));
      const missing = selected.filter((order) => order.status !== "unsigned" && parsePrice(order.settle_price) <= 0);
      if (missing.length) {
        const names = missing.map((order) => order.seller_name || "未填写").join("、");
        alert(`以下订单未填写结算价：${names}`);
        return;
      }
      const lines = selected.map((order) => {
        const date = formatBillDate(order.createdAt);
        const name = order.seller_name || "未填写";
        const model = order.model || "未填写";
        const memory = order.memory || "未填写";
        const color = order.color || "未填写";
        const activation = resolveActivation(order).label;
        const activationText = activation === "未激活" ? "" : ` ${activation}`;
        const settlePrice = order.status === "unsigned" ? "未签合同" : formatPlainPrice(parsePrice(order.settle_price));
        return `${date}-${name}-${model}${activationText} ${memory} ${color}-全款-${settlePrice}`;
      });
      const settlePrices = selected.map((order) => order.status === "unsigned" ? "0" : formatPlainPrice(parsePrice(order.settle_price)));
      const total = selected.reduce((sum, order) => sum + parsePrice(order.settle_price), 0);
      lines.push(`总价：${settlePrices.join("+")}=${formatPlainPrice(total)}元`);
      pendingExportText = lines.join("\n");
      $("exportContent").textContent = pendingExportText;
      openModal("exportModal");
