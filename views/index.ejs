    function importCsv(text) {
      const rows = parseCsv(text.trim());
      if (!rows.length) return;
      const headers = rows[0].map((h) => h.trim());
      const headerToKey = headers.reduce((acc, header) => {
        if (csvLabelToKey[header]) {
          acc[header] = csvLabelToKey[header];
        } else {
          acc[header] = header;
        }
        return acc;
      }, {});
      const required = csvRequiredKeys;
      const mappedKeys = headers.map((header) => headerToKey[header]).filter(Boolean);
      const missing = required.filter((key) => !mappedKeys.includes(key));
      if (missing.length) {
        alert("导入失败：缺少字段 " + missing.join(", "));
        return;
      }
      const result = [];
      let currentMax = getMaxOrderId();
      let exhausted = false;
      rows.slice(1).forEach((row) => {
        if (!row.length) return;
        const data = {};
        headers.forEach((header, idx) => {
          const key = headerToKey[header];
          if (!key) return;
          data[key] = row[idx] ? row[idx].trim() : "";
        });
        if (data.status && orderStatusReverseMap[data.status]) {
          data.status = orderStatusReverseMap[data.status];
        }
        if (data.settlement && orderSettlementReverseMap[data.settlement]) {
          data.settlement = orderSettlementReverseMap[data.settlement];
        }
        const createdAt =
          Number(data.createdAt) ||
          parseDateInput(data.order_date) ||
          parseDateInput(data.createdAt) ||
          getBeijingNow().getTime();
        const nextId = getNextOrderIdFromMax(currentMax);
        if (!nextId) {
          exhausted = true;
          return;
        }
        currentMax = Number(nextId);
        const order = {
          id: nextId,
          seller_name: data.seller_name,
          seller_id: data.seller_id,
          seller_phone: data.seller_phone,
          remark: data.remark,
          actual_model_color: data.actual_model_color,
          sf_no: data.sf_no,
          model: data.model,
          memory: data.memory,
          color: data.color || randomColorForModel(data.model),
          buy_price: data.buy_price,
          settle_price: data.settle_price,
          source: data.source,
          status: data.status || "signed",
          settlement: data.settlement || (data.settle_price ? "settled" : "unsettled"),
          createdAt,
        };
        result.push(applyOrderRules(order));
      });
      if (!result.length) {
        alert("导入失败：没有可用数据");
        return;
      }
      if (exhausted) {
        alert("订单编号已到上限，部分数据未导入");
      }
      orders = result.concat(orders);
      saveOrders();
      ensureSourcesFromOrders();
      renderSourceSelects();
      renderSourceList();
      renderOrders();
      renderHome();
      alert(`导入完成：新增 ${result.length} 条订单`);
    }

    function createOrderFromData(data) {
      const settlementValue = data.settlement || (data.settle_price ? "settled" : "unsettled");
      const dateStamp = parseDateInput(data.order_date);
      const order = {
        id: generateOrderId(),
        seller_name: data.seller_name,
        seller_id: data.seller_id,
        seller_phone: data.seller_phone,
        activation: data.activation || "未激活",
        remark: data.remark,
        actual_model_color: data.actual_model_color,
        sf_no: data.sf_no,
        model: data.model,
        memory: data.memory,
        color: data.color || randomColorForModel(data.model),
        buy_price: data.buy_price,
        settle_price: data.settle_price,
        source: data.source,
        status: data.status || "signed",
        settlement: settlementValue,
        createdAt: dateStamp || getBeijingNow().getTime(),
      };
      return applyOrderRules(order);
    }

    function addOrder(data) {
      const order = createOrderFromData(data);
      if (!isValidOrderId(order.id)) {
        alert("订单编号已到上限，无法继续添加。");
        return;
      }
      orders.unshift(order);
      saveOrders();
      renderOrders();
    }

    function moveToTrash(orderId) {
      const idx = orders.findIndex((item) => item.id === orderId);
      if (idx === -1) return;
      const [removed] = orders.splice(idx, 1);
      trashedOrders.unshift(removed);
      selectedOrderIds.delete(orderId);
      saveOrders();
      saveTrash();
      renderOrders();
      renderTrash();
    }

    function restoreFromTrash(orderId) {
      const idx = trashedOrders.findIndex((item) => item.id === orderId);
      if (idx === -1) return;
      const [restored] = trashedOrders.splice(idx, 1);
      orders.unshift(restored);
      saveOrders();
      saveTrash();
      renderOrders();
      renderTrash();
    }

